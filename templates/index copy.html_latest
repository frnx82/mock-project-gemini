                function openHelpModal() {
                    document.getElementById('helpModal').style.display = 'block';
                }


                // Gemini extra features
                // Patch switchMainTab to support yaml-gen tab
                (function () {
                    var _orig = switchMainTab;
                    window.switchMainTab = function (tab, skipSave) {
                        // Save active tab to URL hash for refresh persistence
                        try { history.replaceState(null, '', '#tab=' + tab); } catch (e) { }

                        var yamlGenView = document.getElementById('view-yaml-gen');
                        if (yamlGenView) yamlGenView.style.display = 'none';
                        var yamlGenBtn = document.getElementById('main-tab-yaml-gen');
                        if (yamlGenBtn) {
                            yamlGenBtn.style.background = 'linear-gradient(135deg,#6f42c1,#4285f4)';
                            yamlGenBtn.style.color = '#fff';
                        }
                        if (tab === 'yaml-gen') {
                            ['view-workloads', 'view-networking', 'view-optimizer', 'view-security'].forEach(function (id) {
                                var el = document.getElementById(id);
                                if (el) el.style.display = 'none';
                            });
                            ['main-tab-workloads', 'main-tab-networking', 'main-tab-optimizer', 'main-tab-security'].forEach(function (id) {
                                var btn = document.getElementById(id);
                                if (btn) { btn.className = 'btn btn-default'; btn.style.background = ''; btn.style.color = ''; }
                            });
                            if (yamlGenView) yamlGenView.style.display = 'block';
                        } else {
                            _orig(tab, skipSave);
                        }
                    };
                })();

                function toggleChatDrawer() {
                    var panel = document.getElementById('chat-panel');
                    if (panel) panel.classList.toggle('open');
                }

                var chatSessionId = localStorage.getItem('gdc-chat-session') ||
                    ('sess-' + Date.now() + '-' + Math.random().toString(36).slice(2, 7));
                localStorage.setItem('gdc-chat-session', chatSessionId);
                var _csl = document.getElementById('chat-session-label');
                if (_csl) _csl.innerText = 'Session: ' + chatSessionId.slice(-6);

                function renderMarkdown(text) {
                    if (!text) return '';
                    return String(text)
                        .replace(/```([\s\S]*?)```/g, function (_, c) {
                            return '<pre style="background:#1e1e2e;color:#cdd6f4;padding:10px;border-radius:6px;overflow-x:auto;font-size:12px;">' + c.trim() + '</pre>';
                        })
                        .replace(/`([^`]+)`/g, '<code style="background:#e8e8f0;padding:1px 4px;border-radius:3px;">$1</code>')
                        .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
                        .replace(/\*([^*]+)\*/g, '<em>$1</em>')
                        .replace(/^### (.+)$/gm, '<h4 style="margin:8px 0 4px;">$1</h4>')
                        .replace(/^- (.+)$/gm, '<li>$1</li>')
                        .replace(/\n\n/g, '</p><p style="margin:4px 0;">')
                        .replace(/\n/g, '<br>');
                }

                function appendChatBubble(role, html) {
                    var box = document.getElementById('chat-messages');
                    if (!box) return null;
                    var div = document.createElement('div');
                    div.className = role === 'user' ? 'chat-bubble user' : 'chat-bubble assistant';
                    div.innerHTML = html;
                    box.appendChild(div);
                    box.scrollTop = box.scrollHeight;
                    return div;
                }

                async function sendChatMessage() {
                    var input = document.getElementById('chat-input');
                    if (!input) return;
                    var query = input.value.trim();
                    if (!query) return;
                    input.value = '';
                    appendChatBubble('user', query);
                    var typing = appendChatBubble('assistant', '<em style="color:#888;">Thinking...</em>');
                    try {
                        var res = await fetch('/api/ai/converse', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ message: query, session_id: chatSessionId })
                        });
                        var data = await res.json();
                        if (typing) typing.innerHTML = renderMarkdown(data.response || data.error || 'No response');
                    } catch (e) {
                        if (typing) typing.innerHTML = '<span style="color:#dc3545;">Error: ' + e.message + '</span>';
                    }
                }

                async function resetChatSession() {
                    try {
                        await fetch('/api/ai/converse/reset', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ session_id: chatSessionId })
                        });
                        chatSessionId = 'sess-' + Date.now() + '-' + Math.random().toString(36).slice(2, 7);
                        localStorage.setItem('gdc-chat-session', chatSessionId);
                        var lbl = document.getElementById('chat-session-label');
                        if (lbl) lbl.innerText = 'Session: ' + chatSessionId.slice(-6);
                        var msgs = document.getElementById('chat-messages');
                        if (msgs) msgs.innerHTML = '<div class="chat-bubble assistant">New session started. How can I help?</div>';
                    } catch (e) {
                        showToast('Failed to reset session: ' + e.message, false);
                    }
                }

                var _currentLogPodName = null;

                function openLogCorrelation() {
                    var modal = document.getElementById('logCorrelateModal');
                    if (!modal) return;
                    var nameEl = document.getElementById('correlate-pod-name');
                    if (nameEl) nameEl.innerText = _currentLogPodName || '(unknown)';
                    var box = document.getElementById('log-correlate-box');
                    if (box) box.innerHTML = '<em style="color:#888;">Loading...</em>';
                    modal.style.display = 'block';
                    var ns = document.getElementById('namespace-select').value;
                    fetch('/api/ai/correlate_logs', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ pod_name: _currentLogPodName, namespace: ns })
                    }).then(function (r) { return r.json(); }).then(function (data) {
                        if (box) box.innerHTML = renderMarkdown(data.correlation || data.summary || data.error || 'No data.');
                    }).catch(function (e) {
                        if (box) box.innerHTML = '<span style="color:#dc3545;">Error: ' + e.message + '</span>';
                    });
                }

                var _origOpenLogsModal = openLogsModal;
                window.openLogsModal = function (podName) {
                    _currentLogPodName = podName;
                    _origOpenLogsModal(podName);
                };

                function setYamlPrompt(text) {
                    var ta = document.getElementById('yaml-prompt');
                    if (ta) { ta.value = text; ta.focus(); }
                }

                function copyYaml() {
                    var el = document.getElementById('yaml-gen-output');
                    if (!el) return;
                    navigator.clipboard.writeText(el.innerText || '').then(function () {
                        showToast('YAML copied to clipboard', true);
                    }).catch(function () {
                        showToast('Copy failed', false);
                    });
                }

                async function generateYaml() {
                    var prompt = (document.getElementById('yaml-prompt').value || '').trim();
                    if (!prompt) { showToast('Please enter a description', false); return; }
                    var loading = document.getElementById('yaml-gen-loading');
                    var output = document.getElementById('yaml-gen-output');
                    if (loading) loading.style.display = 'block';
                    if (output) output.innerText = 'Generating...';
                    var ns = document.getElementById('namespace-select').value;
                    try {
                        var res = await fetch('/api/ai/generate_yaml', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ prompt: prompt, namespace: ns })
                        });
                        var data = await res.json();
                        if (loading) loading.style.display = 'none';
                        if (output) output.innerText = data.yaml || data.error || 'No output';
                    } catch (e) {
                        if (loading) loading.style.display = 'none';
                        if (output) output.innerText = 'Error: ' + e.message;
                    }
                }

                function burstRefresh(n) {
                    var c = 0, tick = function () { fetchData(); if (++c < n) setTimeout(tick, 1000); };
                    tick();
                }


                // ─────────────────────────────────────────────
                // Gemini Workload AI Functions
                // ─────────────────────────────────────────────

                function _getScoreColor(score) {
                    if (score >= 85) return '#28a745';
                    if (score >= 60) return '#fd7e14';
                    return '#dc3545';
                }

                function _makeCopyBtn(text) {
                    return '<button class="copy-btn" onclick="navigator.clipboard.writeText(this.dataset.cmd)" data-cmd="' + text.replace(/"/g, '&quot;') + '">copy</button>';
                }

                // ── Workload Analysis (Deployment / StatefulSet / DaemonSet) ──
                async function openWorkloadAnalysis(name, kind) {
                    var modal = document.getElementById('aiAnalysisModal');
                    var loading = document.getElementById('ai-analysis-loading');
                    var contentDiv = document.getElementById('ai-analysis-content');
                    modal.style.display = 'block';
                    loading.style.display = 'block';
                    contentDiv.style.display = 'none';
                    document.getElementById('ai-analysis-title').innerText = kind + ': ' + name;

                    var ns = document.getElementById('namespace-select').value;
                    try {
                        var res = await fetch('/api/ai/analyze_workload', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ name: name, kind: kind, namespace: ns })
                        });
                        var data = await res.json();
                        loading.style.display = 'none';
                        contentDiv.style.display = 'block';

                        var score = data.health_score || 0;
                        var ring = document.getElementById('ai-health-score-ring');
                        ring.innerText = score;
                        ring.style.background = _getScoreColor(score) + '22';
                        ring.style.color = _getScoreColor(score);
                        ring.style.border = '4px solid ' + _getScoreColor(score);

                        var statusClass = { 'Healthy': 'health-healthy', 'Degraded': 'health-degraded', 'Critical': 'health-critical' }[data.health_status] || 'health-unknown';
                        document.getElementById('ai-health-badge').innerHTML = '<span class="health-badge ' + statusClass + '">' + (data.health_status || 'Unknown') + '</span>';
                        document.getElementById('ai-gemini-tag').innerText = data.gemini_powered ? '✨ Powered by Gemini' : '⚙️ Spec-based check';
                        document.getElementById('ai-analysis-summary').innerText = data.summary || '';

                        var risksHTML = '';
                        if (data.risks && data.risks.length > 0) {
                            risksHTML = '<div style="font-weight:700; margin-bottom:8px; font-size:14px;">&#9888; Risks</div>';
                            data.risks.forEach(function (r) {
                                var cls = { 'Critical': 'risk-critical', 'High': 'risk-high', 'Medium': 'risk-medium', 'Low': 'risk-low' }[r.severity] || '';
                                risksHTML += '<div class="risk-card ' + cls + '">' +
                                    '<strong>' + r.severity + ':</strong> ' + r.description +
                                    (r.action ? '<div style="margin-top:4px; color:#555; font-size:12px;">&#10148; ' + r.action + '</div>' : '') +
                                    '</div>';
                            });
                        }
                        document.getElementById('ai-risks-section').innerHTML = risksHTML;

                        var kubectlHTML = '';
                        if (data.kubectl_hints && data.kubectl_hints.length > 0) {
                            kubectlHTML = '<div style="font-weight:700; margin-bottom:8px; font-size:14px;">&#128196; Debug Commands</div>';
                            data.kubectl_hints.forEach(function (cmd) {
                                kubectlHTML += '<div class="kubectl-hint">' + _makeCopyBtn(cmd) + '<code>' + cmd + '</code></div>';
                            });
                        }
                        document.getElementById('ai-kubectl-section').innerHTML = kubectlHTML;

                        var posHTML = '';
                        if (data.positive_signals && data.positive_signals.length > 0) {
                            posHTML = '<div style="font-weight:700; margin-bottom:8px; font-size:14px; color:#28a745;">&#10003; Positive Signals</div>';
                            posHTML += '<ul style="margin:0; padding-left:20px; color:#555; font-size:13px;">';
                            data.positive_signals.forEach(function (s) { posHTML += '<li>' + s + '</li>'; });
                            posHTML += '</ul>';
                        }
                        document.getElementById('ai-positive-signals').innerHTML = posHTML;

                        document.getElementById('ai-quick-actions').innerHTML =
                            `<button class="btn btn-default" style="font-size:12px;" data-wl-action="events" data-wl-name="${name}">View Events</button>` +
                            `<button class="btn btn-default" style="font-size:12px;" data-wl-action="restart" data-wl-name="${name}" data-wl-kind="${kind}">&#8635; Restart</button>` +
                            (data.error ? '<div style="color:#dc3545; font-size:13px;">Error: ' + data.error + '</div>' : '');
                    } catch (e) {
                        loading.style.display = 'none';
                        contentDiv.style.display = 'block';
                        document.getElementById('ai-analysis-summary').innerText = 'Error: ' + e.message;
                    }
                }

                // ── Pod Full Diagnosis ──
                async function openPodDiagnose(podName) {
                    var modal = document.getElementById('podDiagnoseModal');
                    var loading = document.getElementById('pd-loading');
                    var cont = document.getElementById('pd-content');
                    modal.style.display = 'block';
                    loading.style.display = 'block';
                    cont.style.display = 'none';
                    document.getElementById('pd-title').innerText = 'Diagnosing: ' + podName;

                    var ns = document.getElementById('namespace-select').value;
                    try {
                        var res = await fetch('/api/ai/diagnose_pod', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ pod_name: podName, namespace: ns })
                        });
                        var data = await res.json();
                        loading.style.display = 'none';
                        cont.style.display = 'block';

                        var sevColors = { ok: '#28a745', warning: '#fd7e14', critical: '#dc3545' };
                        var sev = data.severity || 'warning';
                        var badge = document.getElementById('pd-severity-badge');
                        badge.innerText = data.health_status || sev;
                        badge.style.background = (sevColors[sev] || '#888') + '22';
                        badge.style.color = sevColors[sev] || '#888';

                        document.getElementById('pd-root-cause').innerText = data.root_cause || 'No issues detected.';

                        var chHTML = '';
                        if (data.container_health) {
                            chHTML = '<div style="font-weight:700; margin-bottom:8px; font-size:14px;">Container Status</div>';
                            chHTML += '<div style="display:flex; flex-wrap:wrap; gap:8px;">';
                            Object.entries(data.container_health).forEach(function (e) {
                                var cname = e[0], cdata = e[1];
                                var sc = { 'ok': '#28a745', 'warning': '#fd7e14', 'error': '#dc3545' }[cdata.status] || '#888';
                                chHTML += '<div style="background:' + sc + '11; border:1px solid ' + sc + '44; border-radius:6px; padding:8px 14px; min-width:140px;">' +
                                    '<div style="font-weight:700; color:' + sc + '; font-size:12px;">' + cname + '</div>' +
                                    '<div style="font-size:12px; color:#555; margin-top:3px;">' + (cdata.summary || '') + '</div></div>';
                            });
                            chHTML += '</div>';
                        }
                        document.getElementById('pd-container-health').innerHTML = chHTML;

                        var evHTML = '';
                        if (data.evidence && data.evidence.length > 0) {
                            evHTML = '<div style="font-weight:700; margin-bottom:8px; font-size:14px;">Evidence</div>';
                            data.evidence.forEach(function (ev) {
                                evHTML += '<div style="background:#1e1e2e; color:#cdd6f4; border-radius:4px; font-family:monospace; font-size:12px; padding:6px 10px; margin:3px 0;">' + ev + '</div>';
                            });
                        }
                        document.getElementById('pd-evidence').innerHTML = evHTML;

                        var remHTML = '';
                        if (data.remediation_steps && data.remediation_steps.length > 0) {
                            remHTML = '<div style="font-weight:700; margin-bottom:8px; font-size:14px;">&#10003; Remediation Steps</div>';
                            data.remediation_steps.forEach(function (s) {
                                remHTML += '<div style="background:#f8f9fa; border-radius:6px; padding:10px 14px; margin:4px 0; border-left:3px solid #6f42c1;">' +
                                    '<strong>Step ' + (s.step || '') + ':</strong> ' + (s.action || s) +
                                    (s.command ? '<div class="kubectl-hint" style="margin-top:6px;">' + _makeCopyBtn(s.command) + '<code>' + s.command + '</code></div>' : '') +
                                    '</div>';
                            });
                        }
                        document.getElementById('pd-remediation').innerHTML = remHTML;
                    } catch (e) {
                        loading.style.display = 'none';
                        cont.style.display = 'block';
                        document.getElementById('pd-root-cause').innerText = 'Error: ' + e.message;
                    }
                }

                // ── Job Insights ──
                async function openJobInsights(jobName) {
                    var modal = document.getElementById('jobInsightsModal');
                    var loading = document.getElementById('ji-loading');
                    var cont = document.getElementById('ji-content');
                    modal.style.display = 'block';
                    loading.style.display = 'block';
                    cont.style.display = 'none';
                    document.getElementById('ji-title').innerText = 'Job Insights: ' + jobName;

                    var ns = document.getElementById('namespace-select').value;
                    try {
                        var res = await fetch('/api/ai/job_insights', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ job_name: jobName, namespace: ns })
                        });
                        var data = await res.json();
                        loading.style.display = 'none';
                        cont.style.display = 'block';

                        document.getElementById('ji-summary').innerHTML =
                            '<strong>' + (data.status || '') + '</strong><br>' + (data.summary || '');

                        var failHTML = '';
                        if (data.failure_reason && data.failure_reason !== 'No failure detected') {
                            failHTML += '<div style="font-weight:700; margin-bottom:8px; font-size:14px; color:#dc3545;">Failure Reason</div>';
                            failHTML += '<div style="background:#f8d7da; border-radius:6px; padding:12px; color:#721c24; font-size:14px; border-left:4px solid #dc3545;">' + data.failure_reason + '</div>';
                        }
                        if (data.retry_strategy) {
                            failHTML += '<div style="font-weight:700; margin:12px 0 8px; font-size:14px;">Retry Strategy</div>';
                            failHTML += '<div style="background:#e2efda; border-radius:6px; padding:10px; color:#1a6f00; font-size:13px; border-left:4px solid #28a745;">' + data.retry_strategy + '</div>';
                        }
                        if (data.performance_insight) {
                            failHTML += '<div style="font-weight:700; margin:12px 0 8px; font-size:14px;">Performance</div>';
                            failHTML += '<div style="background:#f8f9fa; border-radius:6px; padding:10px; font-size:13px;">' + data.performance_insight + '</div>';
                        }
                        document.getElementById('ji-failure').innerHTML = failHTML;

                        var kubHTML = '';
                        if (data.kubectl_hints && data.kubectl_hints.length > 0) {
                            kubHTML = '<div style="font-weight:700; margin-bottom:8px; font-size:14px;">Debug Commands</div>';
                            data.kubectl_hints.forEach(function (cmd) {
                                kubHTML += '<div class="kubectl-hint">' + _makeCopyBtn(cmd) + '<code>' + cmd + '</code></div>';
                            });
                        }
                        document.getElementById('ji-kubectl').innerHTML = kubHTML;
                    } catch (e) {
                        loading.style.display = 'none';
                        cont.style.display = 'block';
                        document.getElementById('ji-summary').innerText = 'Error: ' + e.message;
                    }
                }

                // ── ConfigMap / Secret Explain ──
                async function openExplainResource(name, kind) {
                    var modal = document.getElementById('explainModal');
                    var loading = document.getElementById('ex-loading');
                    var cont = document.getElementById('ex-content');
                    modal.style.display = 'block';
                    loading.style.display = 'block';
                    cont.style.display = 'none';
                    document.getElementById('ex-title').innerText = (kind === 'Secret' ? '&#127966; Risk Scan' : '&#129504; Explain') + ': ' + name;

                    var ns = document.getElementById('namespace-select').value;
                    try {
                        var res = await fetch('/api/ai/explain_resource', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ name: name, kind: kind, namespace: ns })
                        });
                        var data = await res.json();
                        loading.style.display = 'none';
                        cont.style.display = 'block';

                        var riskColors = { safe: '#28a745', review: '#fd7e14', concern: '#dc3545', unknown: '#888' };
                        var rl = data.risk_level || 'unknown';
                        var riskBadge = '<span style="display:inline-block; padding:4px 14px; border-radius:20px; font-weight:700; font-size:13px; background:' +
                            (riskColors[rl] || '#888') + '22; color:' + (riskColors[rl] || '#888') + ';">' + rl.toUpperCase() + '</span>';
                        if (data.gemini_powered) riskBadge += ' <span style="font-size:12px; color:#888;">✨ Gemini</span>';
                        document.getElementById('ex-risk-badge').innerHTML = riskBadge;

                        document.getElementById('ex-purpose').innerText = data.purpose || '';

                        var keysHTML = '';
                        if (data.key_breakdown && Object.keys(data.key_breakdown).length > 0) {
                            keysHTML = '<div style="font-weight:700; margin-bottom:8px; font-size:14px;">Key Breakdown</div>';
                            keysHTML += '<table style="width:100%; border-collapse:collapse;">';
                            Object.entries(data.key_breakdown).forEach(function (e) {
                                keysHTML += '<tr><td style="font-family:monospace; font-size:12px; color:#6f42c1; font-weight:700; padding:5px 10px; width:35%; vertical-align:top;">' + e[0] + '</td>' +
                                    '<td style="padding:5px; font-size:13px; color:#555;">' + e[1] + '</td></tr>';
                            });
                            keysHTML += '</table>';
                        }
                        document.getElementById('ex-keys').innerHTML = keysHTML;

                        var concHTML = '';
                        if (data.security_concerns && data.security_concerns.length > 0) {
                            concHTML = '<div style="font-weight:700; margin-bottom:8px; font-size:14px; color:#dc3545;">Security Concerns</div>';
                            data.security_concerns.forEach(function (c) {
                                var sev = c.severity || 'Medium';
                                var sevC = { 'Critical': '#dc3545', 'High': '#fd7e14', 'Medium': '#ffc107', 'Low': '#28a745' }[sev] || '#888';
                                concHTML += '<div class="risk-card" style="border-color:' + sevC + ';">' +
                                    '<strong style="color:' + sevC + ';">' + sev + ':</strong> ' + (c.concern || '') +
                                    (c.recommendation ? '<div style="margin-top:4px; color:#555; font-size:12px;">Fix: ' + c.recommendation + '</div>' : '') +
                                    '</div>';
                            });
                        }
                        document.getElementById('ex-concerns').innerHTML = concHTML;

                        var recsHTML = '';
                        if (data.recommendations && data.recommendations.length > 0) {
                            recsHTML = '<div style="font-weight:700; margin-bottom:8px; font-size:14px;">Recommendations</div>';
                            recsHTML += '<ul style="margin:0; padding-left:20px; color:#555; font-size:13px;">';
                            data.recommendations.forEach(function (r) { recsHTML += '<li>' + r + '</li>'; });
                            if (data.rotation_advice) recsHTML += '<li><strong>Rotation:</strong> ' + data.rotation_advice + '</li>';
                            recsHTML += '</ul>';
                        }
                        document.getElementById('ex-recs').innerHTML = recsHTML;
                    } catch (e) {
                        loading.style.display = 'none';
                        cont.style.display = 'block';
                        document.getElementById('ex-purpose').innerText = 'Error: ' + e.message;
                    }
                }

                // ── Multi-Container Logs Modal ──
                async function openMultiContainerLogs(podName) {
                    _currentLogPodName = podName;
                    var modal = document.getElementById('multiLogModal');
                    var loading = document.getElementById('multi-log-loading');
                    var tabsDiv = document.getElementById('multi-log-tabs');
                    var logContent = document.getElementById('multi-log-content');
                    var aiPanel = document.getElementById('ml-ai-panel');
                    var aiLoading = document.getElementById('ml-ai-loading');
                    var aiSummary = document.getElementById('ml-ai-summary-text');
                    var aiErrors = document.getElementById('ml-ai-errors-list');
                    var aiRecs = document.getElementById('ml-ai-recs-list');

                    // Reset state
                    modal.style.display = 'block';
                    loading.style.display = 'block';
                    tabsDiv.innerHTML = '';
                    logContent.style.display = 'none';
                    logContent.innerHTML = '';
                    aiPanel.style.display = 'none';
                    document.getElementById('multi-log-title').innerText = 'Container Logs: ' + podName;
                    document.getElementById('multi-log-subtitle').innerText = '';
                    document.getElementById('ml-btn-errors').style.display = 'none';
                    document.getElementById('ml-btn-correlate').style.display = 'none';
                    document.getElementById('ml-btn-diagnose').style.display = 'none';
                    document.getElementById('ml-btn-diagnose').dataset.wlName = podName;

                    var ns = document.getElementById('namespace-select').value;
                    var allContainerText = {}; // container -> raw text

                    try {
                        // 1) Fetch all container logs
                        var res = await fetch('/api/pods/' + encodeURIComponent(podName) + '/all_logs?namespace=' + encodeURIComponent(ns));
                        if (!res.ok) throw new Error('Server returned ' + res.status + ' — check backend is running with new routes');
                        var data = await res.json();
                        loading.style.display = 'none';

                        allContainerText = data.containers || {};
                        var containerNames = Object.keys(allContainerText);
                        if (containerNames.length === 0) {
                            logContent.style.display = 'block'; logContent.innerText = 'No logs found.'; return;
                        }

                        // 2) Count errors per container for tab badges
                        var errorCounts = {};
                        containerNames.forEach(function (cn) {
                            var lines = (allContainerText[cn] || '').split('\n');
                            errorCounts[cn] = lines.filter(l => /\[(ERROR|FATAL|CRITICAL)\]/.test(l)).length;
                        });
                        var totalErrors = Object.values(errorCounts).reduce((a, b) => a + b, 0);

                        // 3) Build container tabs
                        var currentContainer = containerNames[0];
                        var _renderLog = function (cname) {
                            currentContainer = cname;
                            document.querySelectorAll('.container-log-tab').forEach(function (t) {
                                t.classList.toggle('active', t.dataset.container === cname);
                            });
                            logContent.style.display = 'block';
                            // Colorize log lines
                            var lines = (allContainerText[cname] || '(no output)').split('\n');
                            logContent.innerHTML = lines.map(function (l) {
                                var escaped = l.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
                                if (/\[(FATAL|CRITICAL)\]|FATAL|panic:/.test(l)) return '<span style="color:#ff6b6b;font-weight:700;">' + escaped + '</span>';
                                if (/\[ERROR\]|Error:|Exception:|ConnectionRefused|OOMKilled|ImagePull/.test(l)) return '<span style="color:#ff9999;">' + escaped + '</span>';
                                if (/\[WARN\]/.test(l)) return '<span style="color:#ffb86c;">' + escaped + '</span>';
                                if (/\[INFO\]/.test(l)) return '<span style="color:#8be9fd;">' + escaped + '</span>';
                                return '<span style="color:#c9d1d9;">' + escaped + '</span>';
                            }).join('\n');
                        };

                        tabsDiv.innerHTML = '';
                        containerNames.forEach(function (cname, idx) {
                            var btn = document.createElement('button');
                            var ec = errorCounts[cname];
                            btn.className = 'container-log-tab' + (idx === 0 ? ' active' : '');
                            btn.dataset.container = cname;
                            btn.innerHTML = cname + (ec > 0 ? ` <span style="background:#dc3545;color:white;border-radius:9px;padding:1px 6px;font-size:10px;margin-left:4px;">${ec}</span>` : '');
                            btn.onclick = function () { _renderLog(cname); };
                            tabsDiv.appendChild(btn);
                        });
                        _renderLog(containerNames[0]);

                        // 4) Show action buttons
                        document.getElementById('multi-log-subtitle').innerText = containerNames.length + ' container(s) | ' + (totalErrors > 0 ? totalErrors + ' error(s) found' : 'No errors ✓');
                        if (totalErrors > 0) document.getElementById('ml-btn-errors').style.display = '';
                        document.getElementById('ml-btn-correlate').style.display = '';
                        document.getElementById('ml-btn-diagnose').style.display = '';

                        // 5) Auto-trigger Gemini summary
                        _multiLogRunAISummary(podName, allContainerText, ns);

                    } catch (e) {
                        loading.style.display = 'none';
                        logContent.style.display = 'block';
                        logContent.innerText = 'Error fetching logs: ' + e.message;
                    }
                }

                // Show errors-only view across all containers
                function _multiLogShowErrors() {
                    var logContent = document.getElementById('multi-log-content');
                    var allText = '';
                    // Collect from the currently displayed tab — rely on the global
                    // We store container text in a closure; rebuild from inner HTML
                    var lines = logContent.innerText.split('\n').filter(l => /\[(ERROR|FATAL|CRITICAL)\]|Error:|Exception:|panic:/.test(l));
                    if (lines.length === 0) { logContent.innerHTML = '<span style="color:#8be9fd;">No errors found in current view ✓</span>'; return; }
                    logContent.innerHTML = '<span style="color:#ff6b6b; font-weight:700;">⚠ ERROR LINES ONLY</span>\n' +
                        lines.map(l => '<span style="color:#ff9999;">' + l.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;') + '</span>').join('\n');
                }

                // Gemini Log Analysis called automatically on log open
                async function _multiLogRunAISummary(podName, allContainerText, ns) {
                    var aiPanel = document.getElementById('ml-ai-panel');
                    var aiLoading = document.getElementById('ml-ai-loading');
                    var aiSummary = document.getElementById('ml-ai-summary-text');
                    aiPanel.style.display = 'block';
                    aiLoading.style.display = 'inline';
                    aiSummary.innerText = 'Scanning all container logs for errors, anomalies, and root causes...';
                    document.getElementById('ml-ai-errors-section').style.display = 'none';
                    document.getElementById('ml-ai-recs-section').style.display = 'none';

                    // Combine all logs for summarization
                    var combined = Object.entries(allContainerText).map(([cn, log]) => `=== Container: ${cn} ===\n${log}`).join('\n\n');

                    try {
                        // Try the summarize_logs endpoint (Gemini in prod, mock in dev)
                        var res = await fetch('/api/ai/summarize_logs', {
                            method: 'POST', headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ pod_name: podName, namespace: ns, logs: combined, analyze_all_containers: true })
                        });
                        if (!res.ok) throw new Error('summarize_logs returned ' + res.status);
                        var d = await res.json();
                        aiLoading.style.display = 'none';

                        // Primary summary text
                        aiSummary.innerHTML = (d.summary || d.analysis || 'Analysis complete — no critical issues found.').replace(/\n/g, '<br>');

                        // Error evidence
                        var errs = d.errors || d.anomalies || d.error_evidence || [];
                        if (errs.length > 0) {
                            document.getElementById('ml-ai-errors-section').style.display = 'block';
                            document.getElementById('ml-ai-errors-list').innerHTML = errs.map(e => '• ' + e).join('<br>');
                        }

                        // Recommendations
                        var recs = d.recommendations || d.suggested_fixes || d.actions || [];
                        if (recs.length > 0) {
                            document.getElementById('ml-ai-recs-section').style.display = 'block';
                            document.getElementById('ml-ai-recs-list').innerHTML = recs.map(r => '&#10003; ' + r).join('<br>');
                        }

                        // Update badge
                        document.getElementById('ml-ai-badge').innerText = d.gemini_powered ? 'Gemini AI' : 'Mock AI';
                        document.getElementById('ml-ai-badge').style.background = d.gemini_powered ? '#4285f4' : '#888';

                    } catch (e) {
                        aiLoading.style.display = 'none';
                        aiSummary.innerText = 'AI analysis unavailable: ' + e.message;
                    }
                }

                // ── Restart Workload helper ──
                async function restartWorkload(name, kind) {
                    showConfirm('Rolling restart ' + kind + ' "' + name + '"?', async function () {
                        var ns = document.getElementById('namespace-select').value;
                        try {
                            var res = await fetch('/api/restart', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ name: name, type: kind, namespace: ns })
                            });
                            var data = await res.json();
                            if (data.error) throw new Error(data.error);
                            showToast('↺ ' + data.message, true);
                            setTimeout(fetchData, 2000);
                        } catch (e) { showToast('Restart failed: ' + e.message, false); }
                    }, '🔄');
                }

                // Init — restore last active tab from URL hash (survives Ctrl+R / F5)
                (function () {
                    var hash = window.location.hash; // e.g. "#tab=security"
                    var restoredTab = 'workloads'; // default
                    if (hash && hash.startsWith('#tab=')) {
                        var candidate = hash.slice(5); // strip '#tab='
                        var valid = ['workloads', 'networking', 'optimizer', 'security', 'yaml-gen'];
                        if (valid.indexOf(candidate) !== -1) restoredTab = candidate;
                    }
                    switchMainTab(restoredTab);
                })();
                fetchData();
                refreshInterval = setInterval(fetchData, 5000);
            </script>
</body>

</html>