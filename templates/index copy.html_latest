    <!-- AI Help Modal -->
    <div id="helpModal" class="modal" style="z-index: 102;">
        <div class="modal-content" style="width: 70%; max-width: 760px;">
            <span class="close" onclick="closeModal('helpModal')">&times;</span>
            <div style="display:flex; align-items:center; gap:10px; margin-bottom:4px;">
                <span style="font-size:1.5em;">✨</span>
                <h2
                    style="margin:0; background:linear-gradient(90deg,#4285f4,#0f9d58,#f4b400,#db4437); -webkit-background-clip:text; -webkit-text-fill-color:transparent;">
                    Ask AI — Gemini Command Palette</h2>
            </div>
            <p style="color:#888; margin:0 0 16px; font-size:13px;">Type anything in natural language. Gemini
                understands your intent and acts on it.<br>Click any chip below to instantly run that query.</p>

            <style>
                .help-cat {
                    display: flex;
                    align-items: center;
                    gap: 8px;
                    margin: 14px 0 6px;
                }

                .help-cat-badge {
                    font-size: 11px;
                    font-weight: 700;
                    padding: 2px 10px;
                    border-radius: 10px;
                    color: #fff;
                }

                .help-chips {
                    display: flex;
                    flex-wrap: wrap;
                    gap: 6px;
                    margin-bottom: 4px;
                }

                .help-chip {
                    font-size: 12px;
                    background: #f4f4f4;
                    border: 1px solid #e0e0e0;
                    color: #444;
                    border-radius: 20px;
                    padding: 4px 12px;
                    cursor: pointer;
                    transition: background .12s;
                }

                .help-chip:hover {
                    background: #e8f0fe;
                    border-color: #4285f4;
                    color: #1a73e8;
                }
            </style>

            <div class="help-cat"><span>🔍</span><strong>Filtering &amp; Navigation</strong><span class="help-cat-badge"
                    style="background:#4285f4;">Navigation</span></div>
            <div class="help-chips">
                <span class="help-chip" onclick="useHelpChip(this)">Show failed pods</span>
                <span class="help-chip" onclick="useHelpChip(this)">Show pending pods</span>
                <span class="help-chip" onclick="useHelpChip(this)">List running deployments</span>
                <span class="help-chip" onclick="useHelpChip(this)">Show all workloads</span>
                <span class="help-chip" onclick="useHelpChip(this)">Go to security scan</span>
                <span class="help-chip" onclick="useHelpChip(this)">Navigate to optimizer</span>
                <span class="help-chip" onclick="useHelpChip(this)">Switch to networking</span>
            </div>

            <div class="help-cat"><span>⚙️</span><strong>K8s Operations</strong><span class="help-cat-badge"
                    style="background:#0f9d58;">Actions</span></div>
            <div class="help-chips">
                <span class="help-chip" onclick="useHelpChip(this)">Scale billing-service to 3 replicas</span>
                <span class="help-chip" onclick="useHelpChip(this)">Restart the frontend deployment</span>
                <span class="help-chip" onclick="useHelpChip(this)">Show config for checkout-service</span>
                <span class="help-chip" onclick="useHelpChip(this)">Get YAML for api-gateway</span>
                <span class="help-chip" onclick="useHelpChip(this)">Show events for payment-processor</span>
                <span class="help-chip" onclick="useHelpChip(this)">Delete pod xyz</span>
            </div>

            <div class="help-cat"><span>🔬</span><strong>AI Diagnostics (Developer)</strong><span class="help-cat-badge"
                    style="background:#6f42c1;">AI</span></div>
            <div class="help-chips">
                <span class="help-chip" onclick="useHelpChip(this)">Why is payment-processor crashing?</span>
                <span class="help-chip" onclick="useHelpChip(this)">Analyze the frontend pod</span>
                <span class="help-chip" onclick="useHelpChip(this)">Show logs for checkout-service</span>
                <span class="help-chip" onclick="useHelpChip(this)">Diagnose OOMKilled pods</span>
                <span class="help-chip" onclick="useHelpChip(this)">Why is the pod in ImagePullBackOff?</span>
            </div>

            <div class="help-cat"><span>💰</span><strong>Cost &amp; Optimization (DevOps)</strong><span
                    class="help-cat-badge" style="background:#f4b400; color:#222;">Cost</span></div>
            <div class="help-chips">
                <span class="help-chip" onclick="useHelpChip(this)">What's my monthly compute cost?</span>
                <span class="help-chip" onclick="useHelpChip(this)">Which workloads are over-provisioned?</span>
                <span class="help-chip" onclick="useHelpChip(this)">Run cost optimization analysis</span>
                <span class="help-chip" onclick="useHelpChip(this)">Show me potential savings</span>
                <span class="help-chip" onclick="useHelpChip(this)">Which pods have no resource limits?</span>
            </div>

            <div class="help-cat"><span>🛡️</span><strong>Security &amp; Compliance (DevOps)</strong><span
                    class="help-cat-badge" style="background:#dc3545;">Security</span></div>
            <div class="help-chips">
                <span class="help-chip" onclick="useHelpChip(this)">Run a security scan</span>
                <span class="help-chip" onclick="useHelpChip(this)">Are there any critical vulnerabilities?</span>
                <span class="help-chip" onclick="useHelpChip(this)">Which pods run as root?</span>
                <span class="help-chip" onclick="useHelpChip(this)">Check RBAC permissions</span>
                <span class="help-chip" onclick="useHelpChip(this)">Which images use :latest tag?</span>
            </div>

            <div class="help-cat"><span>💡</span><strong>Explore &amp; Explain (Developer)</strong><span
                    class="help-cat-badge" style="background:#17a2b8;">Explain</span></div>
            <div class="help-chips">
                <span class="help-chip" onclick="useHelpChip(this)">What does this namespace do?</span>
                <span class="help-chip" onclick="useHelpChip(this)">Explain the difference between requests and
                    limits</span>
                <span class="help-chip" onclick="useHelpChip(this)">How do I configure a liveness probe?</span>
                <span class="help-chip" onclick="useHelpChip(this)">What is a StatefulSet vs Deployment?</span>
                <span class="help-chip" onclick="useHelpChip(this)">Generate a Deployment YAML for nginx</span>
            </div>

            <div
                style="margin-top:16px; padding:10px 14px; background:#f0f4ff; border-radius:8px; font-size:12px; color:#555; border-left:3px solid #4285f4;">
                <strong>Pro tip:</strong> Click any chip to instantly run it, or just type naturally — Gemini
                understands synonyms, typos, and freeform descriptions.
            </div>
        </div>
    </div>

    <!-- Terminal Modal -->
    <div id="terminalModal" class="modal">
        <div class="modal-content" style="width: 80%; max-width: 900px; background: #1e1e1e; color: #fff;">
            <span class="close" onclick="closeTerminal()" style="color: #fff;">&times;</span>
            <h2 id="terminal-title" style="color: #fff; margin-top:0;">Terminal</h2>
            <div id="term-debug" style="color: yellow; font-family: monospace; font-size: 12px; margin-bottom: 5px;">
                Status: Initializing...</div>
            <div id="terminal-container" style="width: 100%; height: 500px; background: black;"></div>
            <script>
                let refreshInterval;

                let currentFilter = null; // { target: 'Pod', criteria: { status: 'Failed' } }

                function switchMainTab(tab) {
                    // Persist active tab in URL hash so page refresh restores it
                    try { history.replaceState(null, '', '#tab=' + tab); } catch (e) { }

                    const workloadsBtn = document.getElementById('main-tab-workloads');
                    const networkingBtn = document.getElementById('main-tab-networking');
                    const optimizerBtn = document.getElementById('main-tab-optimizer');
                    const securityBtn = document.getElementById('main-tab-security');

                    const workloadsView = document.getElementById('view-workloads');
                    const networkingView = document.getElementById('view-networking');
                    const optimizerView = document.getElementById('view-optimizer');
                    const securityView = document.getElementById('view-security');

                    // Reset all
                    workloadsBtn.className = 'btn btn-default';
                    networkingBtn.className = 'btn btn-default';
                    optimizerBtn.className = 'btn btn-default';
                    securityBtn.className = 'btn btn-default';

                    workloadsView.style.display = 'none';
                    networkingView.style.display = 'none';
                    optimizerView.style.display = 'none';
                    securityView.style.display = 'none';

                    // Activate selected
                    if (tab === 'workloads') {
                        workloadsBtn.className = 'btn btn-primary';
                        workloadsView.style.display = 'block';
                    } else if (tab === 'networking') {
                        networkingBtn.className = 'btn btn-primary';
                        networkingView.style.display = 'block';
                    } else if (tab === 'optimizer') {
                        optimizerBtn.className = 'btn btn-primary';
                        optimizerView.style.display = 'block';
                        renderOptimizer();
                    } else if (tab === 'security') {
                        securityBtn.className = 'btn btn-primary';
                        securityView.style.display = 'block';
                        renderSecurity();
                    }
                }

                function renderOptimizer() {
                    const loading = document.getElementById('opt-loading');
                    const tbody = document.getElementById('opt-table-body');
                    const costRow = document.getElementById('opt-cost-row');
                    const summaryCard = document.getElementById('opt-summary-card');
                    const filterRow = document.getElementById('opt-filter-row');
                    const currentNamespace = document.getElementById('namespace-select').value;

                    loading.style.display = 'block';
                    tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;color:#888;padding:16px;">🤖 Gemini is analysing your workloads...</td></tr>';
                    costRow.style.display = 'none';
                    summaryCard.style.display = 'none';
                    filterRow.style.display = 'none';

                    fetch(`/api/ai/optimize?namespace=${currentNamespace}`)
                        .then(r => {
                            if (!r.ok) return r.json().then(e => { throw new Error(e.error || r.statusText); });
                            return r.json();
                        })
                        .then(data => {
                            if (data.error) throw new Error(data.error);
                            loading.style.display = 'none';

                            // ── Cost summary cards ────────────────────────
                            const cur = data.total_current_monthly_cost || 0;
                            const rec = data.total_recommended_monthly_cost || 0;
                            const sav = data.total_monthly_saving || 0;
                            const recs = data.recommendations || [];

                            document.getElementById('opt-current-cost').textContent = '€' + cur.toFixed(2);
                            document.getElementById('opt-rec-cost').textContent = '€' + rec.toFixed(2);
                            document.getElementById('opt-saving').textContent = (sav >= 0 ? '€' : '-€') + Math.abs(sav).toFixed(2);
                            document.getElementById('opt-saving').style.color = sav >= 0 ? '#0f9d58' : '#dc3545';
                            document.getElementById('opt-saving-card').style.borderLeftColor = sav >= 0 ? '#0f9d58' : '#dc3545';
                            if (cur > 0) {
                                const pct = ((sav / cur) * 100).toFixed(1);
                                document.getElementById('opt-saving-pct').textContent = (sav >= 0 ? '−' : '+') + Math.abs(pct) + '% of current spend';
                            }
                            document.getElementById('opt-wl-count').textContent = recs.length;
                            const issues = recs.filter(r => r.type && !r.type.includes('Right-Sized')).length;
                            document.getElementById('opt-wl-issues').textContent = issues > 0 ? `${issues} need attention` : 'all right-sized ✅';
                            costRow.style.display = 'flex';

                            // ── Gemini badges ─────────────────────────────
                            document.getElementById('opt-gemini-badge').style.display = 'inline-block';
                            const srcBadge = document.getElementById('opt-source-badge');
                            srcBadge.textContent = data.metrics_source === 'metrics-server' ? '📡 Live Metrics' : '🤖 AI Estimation';
                            srcBadge.style.display = 'inline-block';

                            // ── Summary ───────────────────────────────────
                            if (data.summary) {
                                document.getElementById('opt-summary-text').textContent = data.summary;
                                summaryCard.style.display = 'block';
                            }

                            // ── Filter row ────────────────────────────────
                            filterRow.style.display = 'flex';

                            // ── Render rows ───────────────────────────────
                            tbody.innerHTML = '';
                            window._optAllRows = [];

                            const typeColor = {
                                'Cost Saving': '#0f9d58',
                                'Performance Risk': '#fd7e14',
                                'Stability Risk': '#dc3545',
                                'Right-Sized': '#6c757d'
                            };

                            recs.forEach(rec => {
                                const typeKey = Object.keys(typeColor).find(k => (rec.type || '').includes(k)) || 'Right-Sized';
                                const color = typeColor[typeKey] || '#888';
                                const saving = rec.monthly_saving || 0;
                                const savingHtml = saving === 0
                                    ? '<span style="color:#aaa;">€0</span>'
                                    : saving > 0
                                        ? `<span class="opt-saving-pos">−€${saving.toFixed(2)}/mo</span>`
                                        : `<span class="opt-saving-neg">+€${Math.abs(saving).toFixed(2)}/mo</span>`;

                                // Build suggested config badge group
                                const sugCpu = rec.suggested_cpu_request || rec.suggested_cpu_limit
                                    ? `<span class="opt-config-box">req: ${rec.suggested_cpu_request || '?'}</span><span class="opt-config-box">lim: ${rec.suggested_cpu_limit || '?'}</span>`
                                    : '<span style="color:#aaa;font-size:12px;">—</span>';
                                const sugMem = rec.suggested_mem_request || rec.suggested_mem_limit
                                    ? `<span class="opt-config-box">req: ${rec.suggested_mem_request || '?'}</span><span class="opt-config-box">lim: ${rec.suggested_mem_limit || '?'}</span>`
                                    : '<span style="color:#aaa;font-size:12px;">—</span>';

                                const curCpu = `<span class="opt-config-box">req: ${rec.current_cpu_request || 'not-set'}</span><span class="opt-config-box">lim: ${rec.current_cpu_limit || 'not-set'}</span>`;
                                const curMem = `<span class="opt-config-box">req: ${rec.current_mem_request || 'not-set'}</span><span class="opt-config-box">lim: ${rec.current_mem_limit || 'not-set'}</span>`;

                                // Billing basis indicator
                                const basisBadge = rec.billing_basis === 'usage'
                                    ? '<span style="font-size:10px;background:#fd7e14;color:#fff;border-radius:8px;padding:1px 5px;margin-left:4px;">billed:usage</span>'
                                    : rec.billing_basis === 'requests'
                                        ? '<span style="font-size:10px;background:#6c757d;color:#fff;border-radius:8px;padding:1px 5px;margin-left:4px;">billed:requests</span>'
                                        : '';

                                // kubectl patch snippet
                                const kubectlSnippet = rec.suggested_cpu_request
                                    ? `kubectl set resources ${rec.kind || 'deployment'}/${rec.resource} --requests=cpu=${rec.suggested_cpu_request},memory=${rec.suggested_mem_request || '256Mi'} --limits=cpu=${rec.suggested_cpu_limit || '500m'},memory=${rec.suggested_mem_limit || '512Mi'}`
                                    : rec.action || '';

                                const tr = document.createElement('tr');
                                tr.dataset.type = typeKey;
                                tr.innerHTML = `
                                    <td style="color:${color}; font-weight:bold; white-space:nowrap; font-size:13px;">${rec.type || typeKey}</td>
                                    <td>
                                        <strong>${rec.resource}</strong><br>
                                        <span style="font-size:11px;color:#888;">${rec.kind} · ${rec.replicas || 1} replica${rec.replicas !== 1 ? 's' : ''}</span><br>
                                        <span style="font-size:11px;color:#aaa;">${rec.capacity_headroom_pct !== 'N/A' ? '↕ headroom: ' + rec.capacity_headroom_pct : ''}</span>
                                    </td>
                                    <td style="white-space:nowrap;">
                                        <div>CPU: ${curCpu}</div>
                                        <div style="margin-top:2px;">MEM: ${curMem}</div>
                                    </td>
                                    <td>
                                        <div style="font-size:12px;">CPU: <strong>${rec.actual_usage_cpu || '~unknown'}</strong>${basisBadge}</div>
                                        <div style="font-size:12px; margin-top:2px;">MEM: <strong>${rec.actual_usage_mem || '~unknown'}</strong></div>
                                        <div style="font-size:11px;color:#aaa;margin-top:2px;">billable: ${rec.billable_cores != null ? rec.billable_cores.toFixed(3) + ' cores' : '—'}</div>
                                    </td>
                                    <td style="white-space:nowrap;">
                                        <div>CPU: ${sugCpu}</div>
                                        <div style="margin-top:2px;">MEM: ${sugMem}</div>
                                    </td>
                                    <td>
                                        <div>Now: <strong>€${(rec.current_monthly_cost || 0).toFixed(2)}</strong></div>
                                        <div style="margin-top:2px;">After: <strong style="color:#0f9d58;">€${(rec.recommended_monthly_cost || 0).toFixed(2)}</strong></div>
                                        <div style="margin-top:2px;">${savingHtml}</div>
                                    </td>
                                    <td style="font-size:12px; max-width:200px; word-break:break-word;">
                                        <code style="font-size:10px; background:#f0f0f0; padding:2px 4px; border-radius:3px; display:block; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="${kubectlSnippet}">${kubectlSnippet}</code>
                                        <button class="opt-copy-btn" onclick="navigator.clipboard.writeText('${kubectlSnippet.replace(/'/g, '')}')">📋 Copy</button>
                                    </td>
                                `;
                                tbody.appendChild(tr);

                                // AI Insight row
                                if (rec.ai_insight) {
                                    const ins = document.createElement('tr');
                                    ins.className = 'opt-insight-row';
                                    ins.dataset.type = typeKey;
                                    ins.innerHTML = `<td colspan="7">🤖 ${rec.ai_insight}</td>`;
                                    tbody.appendChild(ins);
                                    window._optAllRows.push(tr, ins);
                                } else {
                                    window._optAllRows.push(tr);
                                }
                            });

                            if (recs.length === 0) {
                                tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:20px;">✅ No optimization opportunities found. Resources are well-sized!</td></tr>';
                            }
                        })
                        .catch(e => {
                            loading.style.display = 'none';
                            tbody.innerHTML = `<tr><td colspan="7" style="color:red;padding:16px;">Error: ${e.message}</td></tr>`;
                        });
                }

                function filterOptType(btn, type) {
                    document.querySelectorAll('.opt-filter-btn').forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    (window._optAllRows || []).forEach(function (row) {
                        row.style.display = (type === 'All' || row.dataset.type === type) ? '' : 'none';
                    });
                }

                function renderSecurity() {
                    const loading = document.getElementById('sec-loading');
                    const tbody = document.getElementById('sec-table-body');
                    const summaryCard = document.getElementById('sec-summary-card');
                    const severityBar = document.getElementById('sec-severity-bar');
                    const catFilters = document.getElementById('sec-cat-filters');
                    const currentNamespace = document.getElementById('namespace-select').value;

                    loading.style.display = 'block';
                    tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;color:#888;">Gemini is analysing your cluster...</td></tr>';
                    summaryCard.style.display = 'none';
                    severityBar.style.display = 'none';
                    catFilters.style.display = 'none';

                    fetch(`/api/ai/security_scan?namespace=${currentNamespace}`)
                        .then(r => {
                            if (!r.ok) return r.json().then(e => { throw new Error(e.error || r.statusText) });
                            return r.json();
                        })
                        .then(data => {
                            if (data.error) throw new Error(data.error);
                            loading.style.display = 'none';

                            // Executive summary
                            if (data.executive_summary) {
                                document.getElementById('sec-summary-text').textContent = data.executive_summary;
                                const badge = document.getElementById('sec-gemini-badge');
                                if (data.gemini_powered !== false) badge.style.display = 'inline-block';
                                summaryCard.style.display = 'block';
                            }

                            // Severity pills
                            const sc = data.severity_counts || {};
                            ['Critical', 'High', 'Medium', 'Low', 'Info'].forEach(s => {
                                document.getElementById('sec-count-' + s.toLowerCase()).textContent = sc[s] || 0;
                            });
                            severityBar.style.display = 'flex';
                            catFilters.style.display = 'flex';

                            // Render findings
                            tbody.innerHTML = '';
                            window._secAllRows = [];
                            const colorMap = { Critical: '#dc3545', High: '#fd7e14', Medium: '#d4a017', Low: '#28a745', Info: '#6c757d' };

                            (data.risks || []).forEach(risk => {
                                const color = colorMap[risk.severity] || '#888';
                                const refs = (risk.cve_references || []).map(r =>
                                    `<span class="sec-ref">${r}</span>`).join('');

                                const tr = document.createElement('tr');
                                tr.dataset.severity = risk.severity;
                                tr.dataset.category = risk.category || 'Other';
                                tr.innerHTML = `
                                    <td style="color:${color}; font-weight:bold; white-space:nowrap;">
                                        ${risk.severity === 'Critical' ? '🔴' : risk.severity === 'High' ? '🟠' : risk.severity === 'Medium' ? '🟡' : risk.severity === 'Low' ? '🟢' : 'ℹ️'}
                                        ${risk.severity}
                                    </td>
                                    <td style="font-size:12px; color:#888;">${risk.category || ''}</td>
                                    <td style="font-weight:500;">${risk.resource}<br><span style="font-size:11px;color:#888;">${risk.kind}</span></td>
                                    <td>${risk.issue}</td>
                                    <td style="font-family:monospace; font-size:12px; background:#1a1a2e; color:#cdd6f4; border-radius:4px; padding:4px 6px;">${risk.remediation}</td>
                                    <td>${refs}</td>
                                `;
                                tbody.appendChild(tr);

                                // AI Insight row
                                if (risk.ai_insight) {
                                    const insight = document.createElement('tr');
                                    insight.className = 'sec-insight-row';
                                    insight.dataset.severity = risk.severity;
                                    insight.dataset.category = risk.category || 'Other';
                                    insight.innerHTML = `<td colspan="6">🤖 ${risk.ai_insight}</td>`;
                                    tbody.appendChild(insight);
                                    window._secAllRows.push(tr, insight);
                                } else {
                                    window._secAllRows.push(tr);
                                }
                            });

                            if ((data.risks || []).length === 0) {
                                tbody.innerHTML = '<tr><td colspan="6" style="text-align:center; padding:20px;">✅ No security risks found. Your cluster looks healthy!</td></tr>';
                            }
                        })
                        .catch(e => {
                            loading.style.display = 'none';
                            tbody.innerHTML = `<tr><td colspan="6" style="color:red;">Error: ${e.message}</td></tr>`;
                        });
                }

                function filterSecCategory(severity) {
                    (window._secAllRows || []).forEach(function (row) {
                        row.style.display = (!severity || row.dataset.severity === severity) ? '' : 'none';
                    });
                }

                function filterSecCat(btn, category) {
                    document.querySelectorAll('.sec-cat-btn').forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    (window._secAllRows || []).forEach(function (row) {
                        row.style.display = (category === 'All' || row.dataset.category === category) ? '' : 'none';
                    });
                }

                async function fetchData() {
                    const currentNamespace = document.getElementById('namespace-select').value;
                    const timestampEl = document.getElementById('last-updated');

                    // Only show "Updating..." if it's been a while or on first load to avoid flickering
                    // timestampEl.innerText = `Updating...`; 

                    try {
                        const [workloadsRes, servicesRes, vsRes] = await Promise.all([
                            fetch(`/api/workloads?namespace=${currentNamespace}`),
                            fetch(`/api/services?namespace=${currentNamespace}`),
                            fetch(`/api/virtualservices?namespace=${currentNamespace}`)
                        ]);

                        if (!workloadsRes.ok) throw new Error(`Workloads API: ${workloadsRes.statusText}`);
                        if (!servicesRes.ok) throw new Error(`Services API: ${servicesRes.statusText}`);
                        if (!vsRes.ok) throw new Error(`VirtualServices API: ${vsRes.statusText}`);

                        const workloads = await workloadsRes.json();
                        const services = await servicesRes.json();
                        const virtualServices = await vsRes.json();

                        if (workloads.error) throw new Error(workloads.error);
                        if (services.error) throw new Error(services.error);

                        renderWorkloads(workloads);
                        renderNetworking(services, virtualServices);
                        updatePodStats(workloads);

                        timestampEl.innerText = `Last updated: ${new Date().toLocaleTimeString()}`;
                        timestampEl.style.color = "#888";
                    } catch (error) {
                        console.error("Fetch error", error);
                        timestampEl.innerText = `⚠️ Update Failed: ${error.message}`;
                        timestampEl.style.color = "red";
                    }
                }

                // ── Ask AI Suggestions Data ─────────────────────────────────────────
                const AI_SUGGESTIONS = [
                    // K8s Operations
                    { icon: '🔍', text: 'Show failed pods', badge: 'Filter', color: '#4285f4' },
                    { icon: '🔍', text: 'Show pending pods', badge: 'Filter', color: '#4285f4' },
                    { icon: '🔍', text: 'List running deployments', badge: 'Filter', color: '#4285f4' },
                    { icon: '🔍', text: 'Show all workloads', badge: 'Filter', color: '#4285f4' },
                    { icon: '⚙️', text: 'Scale billing-service to 3 replicas', badge: 'Action', color: '#0f9d58' },
                    { icon: '⚙️', text: 'Restart the frontend deployment', badge: 'Action', color: '#0f9d58' },
                    { icon: '⚙️', text: 'Show config for checkout-service', badge: 'Action', color: '#0f9d58' },
                    { icon: '⚙️', text: 'Get YAML for api-gateway', badge: 'Action', color: '#0f9d58' },
                    { icon: '⚙️', text: 'Show events for payment-processor', badge: 'Action', color: '#0f9d58' },
                    // AI Diagnostics
                    { icon: '🔬', text: 'Why is payment-processor crashing?', badge: 'Diagnose', color: '#6f42c1' },
                    { icon: '🔬', text: 'Analyze the frontend pod', badge: 'Diagnose', color: '#6f42c1' },
                    { icon: '🔬', text: 'Show logs for checkout-service', badge: 'Diagnose', color: '#6f42c1' },
                    { icon: '🔬', text: "What's wrong with database-statefulset?", badge: 'Diagnose', color: '#6f42c1' },
                    { icon: '🔬', text: 'Diagnose OOMKilled pods', badge: 'Diagnose', color: '#6f42c1' },
                    { icon: '🔬', text: 'Why is the pod in ImagePullBackOff?', badge: 'Diagnose', color: '#6f42c1' },
                    // Cost
                    { icon: '💰', text: "What's my monthly compute cost?", badge: 'Cost', color: '#e37400' },
                    { icon: '💰', text: 'Which workloads are over-provisioned?', badge: 'Cost', color: '#e37400' },
                    { icon: '💰', text: 'Run cost optimization analysis', badge: 'Cost', color: '#e37400' },
                    { icon: '💰', text: 'Show me potential savings', badge: 'Cost', color: '#e37400' },
                    { icon: '💰', text: 'Which pods have no resource limits?', badge: 'Cost', color: '#e37400' },
                    // Security
                    { icon: '🛡️', text: 'Run a security scan', badge: 'Security', color: '#dc3545' },
                    { icon: '🛡️', text: 'Are there any critical vulnerabilities?', badge: 'Security', color: '#dc3545' },
                    { icon: '🛡️', text: 'Which pods run as root?', badge: 'Security', color: '#dc3545' },
                    { icon: '🛡️', text: 'Check RBAC permissions', badge: 'Security', color: '#dc3545' },
                    { icon: '🛡️', text: 'Which images use :latest tag?', badge: 'Security', color: '#dc3545' },
                    // Explain
                    { icon: '💡', text: 'What does this namespace do?', badge: 'Explain', color: '#17a2b8' },
                    { icon: '💡', text: 'Explain requests vs limits', badge: 'Explain', color: '#17a2b8' },
                    { icon: '💡', text: 'How do I configure a liveness probe?', badge: 'Explain', color: '#17a2b8' },
                    { icon: '💡', text: 'What is a StatefulSet vs Deployment?', badge: 'Explain', color: '#17a2b8' },
                    { icon: '💡', text: 'Explain ImagePullBackOff', badge: 'Explain', color: '#17a2b8' },
                    { icon: '💡', text: 'Generate a Deployment YAML for nginx', badge: 'Explain', color: '#17a2b8' },
                    { icon: '🔄', text: 'Go to security scan', badge: 'Navigate', color: '#555' },
                    { icon: '🔄', text: 'Navigate to optimizer', badge: 'Navigate', color: '#555' },
                    { icon: '🔄', text: 'Switch to networking tab', badge: 'Navigate', color: '#555' },
                ];
                let _aiHighlighted = -1;
                let _aiFiltered = [];

                function showAISuggestions() {
                    document.getElementById('ask-ai-outer').classList.add('focused');
                    const q = document.getElementById('ai-query-input').value.trim().toLowerCase();
                    _aiFiltered = q ? AI_SUGGESTIONS.filter(s => s.text.toLowerCase().includes(q)) : AI_SUGGESTIONS;
                    _renderAISuggestions();
                }

                function filterAISuggestions(val) {
                    const q = val.trim().toLowerCase();
                    _aiFiltered = q ? AI_SUGGESTIONS.filter(s => s.text.toLowerCase().includes(q)) : AI_SUGGESTIONS;
                    _aiHighlighted = -1;
                    _renderAISuggestions();
                    // Hide toast if open
                    document.getElementById('ai-message-toast').style.display = 'none';
                }

                function _renderAISuggestions() {
                    const panel = document.getElementById('ask-ai-suggestions');
                    if (!_aiFiltered.length) { panel.style.display = 'none'; return; }
                    panel.innerHTML = _aiFiltered.slice(0, 12).map((s, i) => `
                        <div class="ask-ai-item" role="option" data-idx="${i}"
                             onmousedown="_pickAISuggestion(${i})">
                            <span>${s.icon}</span>
                            <span style="flex:1">${s.text}</span>
                            <span class="ask-ai-badge" style="background:${s.color}20; color:${s.color}; border:1px solid ${s.color}40;">${s.badge}</span>
                        </div>`).join('');
                    panel.style.display = 'block';
                }

                function _pickAISuggestion(idx) {
                    const s = _aiFiltered[idx];
                    if (!s) return;
                    document.getElementById('ai-query-input').value = s.text;
                    document.getElementById('ask-ai-suggestions').style.display = 'none';
                    handleAIQuery();
                }

                function handleAIKeydown(e) {
                    const panel = document.getElementById('ask-ai-suggestions');
                    const items = panel.querySelectorAll('.ask-ai-item');
                    if (e.key === 'ArrowDown') {
                        e.preventDefault();
                        _aiHighlighted = Math.min(_aiHighlighted + 1, items.length - 1);
                        items.forEach((el, i) => el.classList.toggle('highlighted', i === _aiHighlighted));
                    } else if (e.key === 'ArrowUp') {
                        e.preventDefault();
                        _aiHighlighted = Math.max(_aiHighlighted - 1, 0);
                        items.forEach((el, i) => el.classList.toggle('highlighted', i === _aiHighlighted));
                    } else if (e.key === 'Enter') {
                        if (_aiHighlighted >= 0 && panel.style.display !== 'none') {
                            _pickAISuggestion(_aiHighlighted);
                        } else {
                            panel.style.display = 'none';
                            handleAIQuery();
                        }
                    } else if (e.key === 'Escape') {
                        panel.style.display = 'none';
                        document.getElementById('ask-ai-outer').classList.remove('focused');
                    }
                }

                function useHelpChip(el) {
                    document.getElementById('ai-query-input').value = el.textContent.trim();
                    closeModal('helpModal');
                    handleAIQuery();
                }

                function _setAILoading(on) {
                    const outer = document.getElementById('ask-ai-outer');
                    const spinner = document.getElementById('ask-ai-spinner');
                    const input = document.getElementById('ai-query-input');
                    if (on) { outer.classList.add('loading'); spinner.style.display = 'block'; input.disabled = true; }
                    else { outer.classList.remove('loading'); spinner.style.display = 'none'; input.disabled = false; }
                }

                function _showAIReply(msg, persist) {
                    const toast = document.getElementById('ai-message-toast');
                    toast.innerHTML = msg;
                    toast.style.display = 'block';
                    if (!persist) setTimeout(() => { toast.style.display = 'none'; }, 6000);
                }

                // Close suggestions on outside click
                document.addEventListener('click', function (e) {
                    if (!document.getElementById('ask-ai-wrap').contains(e.target)) {
                        document.getElementById('ask-ai-suggestions').style.display = 'none';
                        document.getElementById('ask-ai-outer').classList.remove('focused');
                    }
                });

                async function handleAIQuery() {
                    const input = document.getElementById('ai-query-input');
                    const query = input.value.trim();
                    if (!query) return;

                    document.getElementById('ask-ai-suggestions').style.display = 'none';
                    _setAILoading(true);

                    const ns = document.getElementById('namespace-select').value;

                    try {
                        const resp = await fetch('/api/ai/query', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ query, namespace: ns })
                        });
                        const data = await resp.json();
                        _setAILoading(false);

                        if (data.action === 'filter') {
                            currentFilter = { target: data.target, criteria: data.criteria };
                            if (['Pod', 'Deployment', 'Job', 'StatefulSet', 'DaemonSet'].includes(data.target)) {
                                switchMainTab('workloads');
                                setTimeout(() => switchTab('workloads', data.target), 50);
                            } else if (['Service', 'VirtualService', 'Ingress'].includes(data.target)) {
                                switchMainTab('networking');
                                setTimeout(() => switchTab('networking', data.target), 50);
                            }
                            fetchData();
                            showToast('✨ ' + data.message, true);

                        } else if (data.action === 'scale') {
                            const resource = await findResourceByName(data.target, ['Deployment', 'StatefulSet']);
                            if (resource) {
                                await fetch('/api/scale', {
                                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                                    body: JSON.stringify({ name: resource.name, type: resource.type, action: 'set', count: data.count, namespace: ns })
                                });
                                fetchData();
                                showToast('🚀 ' + data.message, true);
                            } else showToast(`Could not find resource matching "${data.target}"`, false);

                        } else if (data.action === 'logs') {
                            const resource = await findResourceByName(data.target, ['Pod']);
                            if (resource) { openLogsModal(resource.name); showToast('📋 ' + data.message, true); }
                            else showToast(`Could not find pod matching "${data.target}"`, false);

                        } else if (data.action === 'delete') {
                            const resource = await findResourceByName(data.target, ['Pod', 'Deployment', 'Service']);
                            if (resource) { deleteResource(resource.name, resource.type); showToast('🗑️ ' + data.message, true); }
                            else showToast(`Could not find resource matching "${data.target}"`, false);

                        } else if (data.action === 'describe') {
                            const resource = await findResourceByName(data.target, ['Deployment', 'Pod', 'Service']);
                            if (resource) openEnvModal(resource.name, resource.type);
                            else showToast(`Could not find resource matching "${data.target}"`, false);

                        } else if (data.action === 'analyze') {
                            const resource = await findResourceByName(data.target, ['Pod', 'Deployment', 'StatefulSet', 'DaemonSet']);
                            if (resource) analyzeResource(resource.name, resource.type, resource.status);
                            else showToast(`Could not find resource matching "${data.target}"`, false);

                        } else if (data.action === 'restart') {
                            // Show inline confirm inside the toast — no flickering browser dialog
                            _showAIReply(`
                                <span>♻️ <strong>Restart ${data.target}?</strong> This triggers a rolling restart.</span>
                                <div style="display:flex;gap:8px;margin-top:8px;">
                                    <button onmousedown="(async()=>{
                                        document.getElementById('ai-message-toast').style.display='none';
                                        const res = await fetch('/api/restart',{method:'POST',headers:{'Content-Type':'application/json'},
                                            body:JSON.stringify({name:'${data.target}',type:'Deployment',namespace:'${ns}'})}).then(r=>r.json());
                                        showToast(res.error ? '❌ '+res.error : '♻️ '+res.message, !res.error);
                                    })()"
                                    style="background:#0f9d58;color:#fff;border:none;border-radius:6px;padding:5px 14px;cursor:pointer;font-size:13px;">
                                    ✅ Confirm
                                    </button>
                                    <button onmousedown="document.getElementById('ai-message-toast').style.display='none'"
                                    style="background:#555;color:#fff;border:none;border-radius:6px;padding:5px 14px;cursor:pointer;font-size:13px;">
                                    Cancel
                                    </button>
                                </div>`, true);

                        } else if (data.action === 'events') {
                            const resource = await findResourceByName(data.target, []);
                            if (resource) openEventsModal(resource.name);
                            else showToast(`Could not find resource "${data.target}"`, false);

                        } else if (data.action === 'yaml') {
                            const resource = await findResourceByName(data.target, []);
                            if (resource) openYamlModal(resource.name, resource.type);
                            else showToast(`Could not find resource "${data.target}"`, false);

                        } else if (data.action === 'navigate') {
                            // target is a tab name: workloads / networking / optimizer / security / yaml-gen
                            switchMainTab(data.target);
                            showToast('🔄 ' + data.message, true);
                            // Auto-trigger relevant scans when navigating
                            if (data.target === 'optimizer') setTimeout(() => { if (typeof renderOptimizer === 'function') renderOptimizer(); }, 300);
                            if (data.target === 'security') setTimeout(() => { if (typeof renderSecurityScan === 'function') renderSecurityScan(); }, 300);

                        } else if (data.action === 'optimize') {
                            // User asked about cost/provisioning
                            switchMainTab('optimizer');
                            showToast('💰 ' + data.message, true);
                            setTimeout(() => { if (typeof renderOptimizer === 'function') renderOptimizer(); }, 300);

                        } else if (data.action === 'security') {
                            // User asked about security posture
                            switchMainTab('security');
                            showToast('🛡️ ' + data.message, true);
                            setTimeout(() => { if (typeof renderSecurityScan === 'function') renderSecurityScan(); }, 300);

                        } else if (data.action === 'chat' || data.action === 'explain') {
                            // Show AI reply in the dark toast panel - persistent until next query
                            const replyText = data.reply || data.message || '🤖 Gemini replied.';
                            let html = `<div style="display:flex;align-items:flex-start;gap:8px;"><span style="font-size:1.2em;flex-shrink:0;">🤖</span><div>`;
                            html += `<div style="font-weight:600; color:#7eb7ff; margin-bottom:4px;">Gemini</div>`;
                            html += `<div style="color:#ddd; line-height:1.6; white-space:pre-wrap;">${replyText.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>').replace(/\n/g, '<br>')}</div>`;
                            if (data.suggestion) {
                                html += `<button class="btn btn-primary btn-sm" style="margin-top:8px;" onclick="document.getElementById('ai-query-input').value='${data.suggestion.action_payload}';handleAIQuery();">→ ${data.suggestion.text}</button>`;
                            }
                            html += `</div></div>`;
                            html += `<button onclick="document.getElementById('ai-message-toast').style.display='none'" style="position:absolute;top:6px;right:10px;background:none;border:none;color:#888;cursor:pointer;font-size:16px;">✕</button>`;
                            const toast = document.getElementById('ai-message-toast');
                            toast.style.position = 'absolute';
                            toast.innerHTML = html;
                            toast.style.display = 'block';
                            input.value = '';  // Clear input after explain
                            return; // Don't clear below

                        } else if (data.action === 'reset') {
                            currentFilter = null;
                            fetchData();
                            showToast(data.message, true);

                        } else {
                            showToast(`🤖 ${data.message || 'Done'}`, true);
                        }

                        if (!['chat', 'explain'].includes(data.action)) input.value = '';

                    } catch (e) {
                        _setAILoading(false);
                        showToast('❌ AI Error: ' + e.message, false);
                    }
                }

                // Helper to find resource from currently fetched data (would be better to have centralized store)
                async function findResourceByName(partialName, types) {
                    // Quick fetch to search
                    const currentNamespace = document.getElementById('namespace-select').value;
                    const [wRes, sRes] = await Promise.all([
                        fetch(`/api/workloads?namespace=${currentNamespace}`),
                        fetch(`/api/services?namespace=${currentNamespace}`)
                    ]);
                    const workloads = await wRes.json();
                    const services = await sRes.json();
                    const all = [...workloads, ...services];

                    return all.find(item => item.name.includes(partialName) && (types.length === 0 || types.includes(item.type)));
                }

                async function deleteResource(name, type) {
                    if (!confirm(`AI Action: Are you sure you want to DELETE ${type} ${name}?`)) return;
                    try {
                        const ns = document.getElementById('namespace-select').value;
                        await fetch('/api/delete', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ name: name, type: type, namespace: ns })
                        });
                        showToast(`Deleted ${name}`, true);
                        fetchData();
                    } catch (e) { alert(e); }
                }

                function showToast(msg, autoHide) {
                    const toast = document.getElementById('ai-message-toast');
                    toast.innerText = msg; // Basic text, mocked markdown support
                    toast.style.display = 'block';
                    if (autoHide) {
                        setTimeout(() => { toast.style.display = 'none'; }, 4000);
                    }
                }

                function updatePodStats(workloads) {
                    const pods = workloads.filter(w => w.type === 'Pod');
                    const running = pods.filter(p => p.status === 'Running').length;
                    const pending = pods.filter(p => p.status === 'Pending').length;
                    const failed = pods.filter(p => p.status === 'Failed' || p.status === 'CrashLoopBackOff' || p.status === 'Error').length;

                    const el = document.getElementById('pod-status-summary');
                    el.innerHTML = `
                        Pod Status: 
                        <span style="color:green; margin-left: 5px;">Running: ${running}</span>
                        <span style="color:orange; margin-left: 10px;">Pending: ${pending}</span>
                        <span style="color:red; margin-left: 10px;">Failed: ${failed}</span>
                    `;
                }

                // ─── Job status badge helper ───
                function jobStatusBadge(item) {
                    const a = item.job_active || 0, s = item.job_succeeded || 0,
                        f = item.job_failed || 0, c = item.job_completions || 1;
                    const st = item.status;
                    if (st === 'Succeeded') return `<span class="job-status-badge job-succeeded">&#10003; Completed ${s}/${c}</span>`;
                    if (st === 'Failed') return `<span class="job-status-badge job-failed">&#10007; Failed &bull; ${f} failed</span>`;
                    if (st === 'Running') return `<span class="job-status-badge job-running">&#9654; Running &bull; ${a} active</span>`;
                    return `<span class="job-status-badge job-pending">&#8987; Pending</span>`;
                }

                // ─── Delegated click handling for workload table action buttons ───
                // All action data is stored in data-* attributes to avoid any string
                // quoting issues inside HTML onclick= attributes.
                document.addEventListener('click', function (e) {
                    const btn = e.target.closest('[data-wl-action]');
                    if (!btn) return;
                    const ns = document.getElementById('namespace-select').value;
                    const action = btn.dataset.wlAction;
                    const name = btn.dataset.wlName || '';
                    const kind = btn.dataset.wlKind || '';
                    const cjson = btn.dataset.wlCjson || '[]';

                    if (action === 'scale-down') scaleWorkload(name, kind, 'down');
                    else if (action === 'scale-up') scaleWorkload(name, kind, 'up');
                    else if (action === 'analyze') openWorkloadAnalysis(name, kind);
                    else if (action === 'config') openEnvModal(name, kind);
                    else if (action === 'restart') restartWorkload(name, kind);
                    else if (action === 'events') openEventsModal(name);
                    else if (action === 'job-insights') openJobInsights(name);
                    else if (action === 'multi-logs') openMultiContainerLogs(name);
                    else if (action === 'diagnose') openPodDiagnose(name);
                    else if (action === 'correlate') { _currentLogPodName = name; openLogCorrelation(); }
                    else if (action === 'terminal') openTerminalPrompt(name, cjson);
                    else if (action === 'cm-view') openConfigMapModal(name);
                    else if (action === 'explain-cm') openExplainResource(name, 'ConfigMap');
                    else if (action === 'secret-view') openSecretModal(name);
                    else if (action === 'explain-secret') openExplainResource(name, 'Secret');
                    else if (action === 'logs') openLogsModal(name);
                });

                function _wBtn(cssClass, label, action, name, kind, extra) {
                    const xtra = extra || '';
                    return `<button class="${cssClass}" data-wl-action="${action}" data-wl-name="${name}" data-wl-kind="${kind}" ${xtra}>${label}</button>`;
                }

                function renderWorkloads(data) {
                    const tabsContainer = document.getElementById('workloads-tabs');
                    const contentContainer = document.getElementById('workloads-content');

                    if (tabsContainer.children.length === 0) {
                        const types = ['Deployment', 'StatefulSet', 'DaemonSet', 'Job', 'Pod', 'ConfigMap', 'Secret'];
                        let tabBtns = '', contentDivs = '';
                        types.forEach((type, index) => {
                            const active = index === 0 ? 'active' : '';
                            tabBtns += `<button class="tab-btn ${active}" onclick="switchTab('workloads','${type}')">${type}s</button>`;
                            contentDivs += `<div id="workloads-${type}" class="tab-content ${active}"></div>`;
                        });
                        tabsContainer.innerHTML = tabBtns;
                        contentContainer.innerHTML = contentDivs;
                    }

                    const types = ['Deployment', 'StatefulSet', 'DaemonSet', 'Job', 'Pod', 'ConfigMap', 'Secret'];
                    types.forEach(type => {
                        let items = data.filter(i => i.type === type);

                        if (currentFilter && currentFilter.target === type && currentFilter.criteria.status) {
                            const sc = currentFilter.criteria.status;
                            if (sc === 'Failed') items = items.filter(i => ['Failed', 'Error', 'CrashLoopBackOff', 'OOMKilled', 'ImagePullBackOff', 'ErrImagePull'].includes(i.status));
                            else if (sc === 'Running') items = items.filter(i => i.status === 'Running');
                            else if (sc === 'Pending') items = items.filter(i => i.status === 'Pending');
                        }

                        const container = document.getElementById(`workloads-${type}`);
                        if (items.length === 0) {
                            container.innerHTML = (currentFilter && currentFilter.target === type)
                                ? '<p>No resources found matching filter.</p>'
                                : '<p>No resources found.</p>';
                            return;
                        }

                        const statusHeader = type === 'Job'
                            ? '<th>Status</th><th>Progress</th>'
                            : '<th>Status</th><th>Ready</th>';

                        let html = `<table><thead><tr><th>Name</th>${statusHeader}<th>Age</th><th>Actions</th></tr></thead><tbody>`;

                        items.forEach(item => {
                            let statusColor = (item.status === 'Running' || (item.status && item.status.includes('/'))) ? 'green' : '#f0ad4e';
                            if (['Failed', 'CrashLoopBackOff', 'Error', 'OOMKilled'].includes(item.status)) statusColor = '#dc3545';
                            if (item.status === 'Succeeded') statusColor = '#28a745';

                            let statusCell = '', readyCell = '';
                            if (type === 'Job') {
                                statusCell = `<td>${jobStatusBadge(item)}</td>`;
                                const jc = item.job_completions || 1, js = item.job_succeeded || 0;
                                const pct = Math.round((js / jc) * 100);
                                readyCell = `<td><div style="background:#e9ecef;border-radius:4px;height:8px;width:80px;overflow:hidden;display:inline-block;vertical-align:middle;"><div style="background:#28a745;height:100%;width:${pct}%;"></div></div><span style="font-size:11px;color:#666;margin-left:6px;">${js}/${jc}</span></td>`;
                            } else {
                                statusCell = `<td style="color:${statusColor};font-weight:500;">${item.status}</td>`;
                                readyCell = `<td>${item.ready}/${item.total}</td>`;
                            }

                            // Build actions using _wBtn helper (data attributes, no inline quotes)
                            let actions = '<div style="display:flex;gap:4px;flex-wrap:wrap;">';

                            if (type === 'Deployment' || type === 'StatefulSet') {
                                actions += _wBtn('btn btn-default', '&#8722;', 'scale-down', item.name, item.type);
                                actions += _wBtn('btn btn-default', '&#43;', 'scale-up', item.name, item.type);
                                actions += _wBtn('ai-btn ai-btn-analyze', '&#129302; Analyze', 'analyze', item.name, item.type);
                                actions += _wBtn('btn btn-default', 'Config', 'config', item.name, item.type);
                                actions += _wBtn('btn btn-default', '&#8635; Restart', 'restart', item.name, item.type);
                                actions += _wBtn('btn btn-default', 'Events', 'events', item.name, '');
                            } else if (type === 'DaemonSet') {
                                actions += _wBtn('ai-btn ai-btn-analyze', '&#129302; Analyze', 'analyze', item.name, 'DaemonSet');
                                actions += _wBtn('btn btn-default', 'Config', 'config', item.name, 'DaemonSet');
                                actions += _wBtn('btn btn-default', 'Events', 'events', item.name, '');
                            } else if (type === 'Job') {
                                actions += _wBtn('ai-btn ai-btn-insights', '&#129504; AI Insights', 'job-insights', item.name, 'Job');
                                actions += _wBtn('btn btn-default', 'Events', 'events', item.name, '');
                            } else if (type === 'Pod') {
                                const cjson = encodeURIComponent(JSON.stringify(item.containers || []));
                                actions += `<button class="btn btn-primary" style="font-size:12px;padding:3px 8px;" data-wl-action="terminal" data-wl-name="${item.name}" data-wl-kind="Pod" data-wl-cjson="${cjson}">Console</button>`;
                                actions += _wBtn('btn btn-default', '&#128196; Logs', 'multi-logs', item.name, 'Pod');
                                actions += _wBtn('ai-btn ai-btn-diagnose', '&#129692; Diagnose', 'diagnose', item.name, 'Pod');
                                actions += _wBtn('ai-btn ai-btn-correlate', '&#128279; Correlate', 'correlate', item.name, 'Pod');
                                actions += _wBtn('btn btn-default', 'Config', 'config', item.name, 'Pod');
                            } else if (type === 'ConfigMap') {
                                actions += _wBtn('btn btn-default', 'View', 'cm-view', item.name, 'ConfigMap');
                                actions += _wBtn('ai-btn ai-btn-explain', '&#129504; Explain', 'explain-cm', item.name, 'ConfigMap');
                            } else if (type === 'Secret') {
                                actions += _wBtn('btn btn-default', 'View', 'secret-view', item.name, 'Secret');
                                actions += _wBtn('ai-btn ai-btn-risk', '&#9888; Risk Scan', 'explain-secret', item.name, 'Secret');
                            }

                            actions += '</div>';
                            html += `<tr><td style="font-weight:600;max-width:200px;word-break:break-word;">${item.name}</td>${statusCell}${readyCell}<td style="color:#888;font-size:12px;">${item.age || '--'}</td><td>${actions}</td></tr>`;
                        });

                        html += '</tbody></table>';
                        container.innerHTML = html;
                    });
                }

                function renderNetworking(services, virtualServices) {
                    const tabsContainer = document.getElementById('networking-tabs');
                    const contentContainer = document.getElementById('networking-content');

                    // Only render tabs once
                    if (tabsContainer.children.length === 0) {
                        const types = ['Service', 'VirtualService'];
                        let tabBtns = '';
                        let contentDivs = '';

                        types.forEach((type, index) => {
                            const isActive = index === 0 ? 'active' : '';
                            tabBtns += `<button class="tab-btn ${isActive}" onclick="switchTab('networking', '${type}')">${type}s</button>`;
                            contentDivs += `<div id="networking-${type}" class="tab-content ${isActive}"></div>`;
                        });

                        tabsContainer.innerHTML = tabBtns;
                        contentContainer.innerHTML = contentDivs;
                    }

                    // Services
                    const svcContainer = document.getElementById('networking-Service');
                    if (services.length > 0) {
                        let html = `<table><thead><tr><th>Name</th><th>Type</th><th>Cluster IP</th><th>Ports</th><th>Age</th></tr></thead><tbody>`;
                        html += services.map(s => `
                    <tr>
                        <td>${s.name}</td>
                        <td>${s.type}</td>
                        <td>${s.cluster_ip}</td>
                        <td>${s.ports}</td>
                        <td>${s.age}</td>
                    </tr>
                `).join('');
                        html += `</tbody></table>`;
                        svcContainer.innerHTML = html;
                    } else {
                        svcContainer.innerHTML = '<p>No Services found.</p>';
                    }

                    // VirtualServices
                    const vsContainer = document.getElementById('networking-VirtualService');
                    if (virtualServices.length > 0) {
                        let html = `<table><thead><tr><th>Name</th><th>Hosts</th><th>Gateways</th><th>Age</th></tr></thead><tbody>`;
                        html += virtualServices.map(vs => {
                            // Ensure hosts is an array and handle comma-separated strings
                            let hosts = Array.isArray(vs.hosts) ? vs.hosts : (vs.hosts.includes(',') ? vs.hosts.split(',') : [vs.hosts]);
                            let hostLinks = hosts.map(h => {
                                h = h.trim();
                                if (h === '*') return '*'; // Don't link wildcard
                                let url = h.startsWith('http') ? h : 'http://' + h;
                                return '<a href="' + url + '" target="_blank" style="color: #4da6ff; text-decoration: underline;">' + h + '</a>';
                            }).join(', ');

                            return `
                    <tr>
                        <td>${vs.name}</td>
                        <td>${hostLinks}</td>
                        <td>${vs.gateways}</td>
                        <td>${vs.age}</td>
                    </tr>
                `}).join('');
                        html += `</tbody></table>`;
                        vsContainer.innerHTML = html;
                    } else {
                        vsContainer.innerHTML = '<p>No VirtualServices found.</p>';
                    }
                }

                function switchTab(panel, type) {
                    const tabsContainer = document.getElementById(`${panel}-tabs`);
                    const contentContainer = document.getElementById(`${panel}-content`);

                    // Update buttons
                    Array.from(tabsContainer.children).forEach(btn => {
                        btn.classList.toggle('active', btn.innerText.includes(type));
                    });

                    // Update content visibility
                    Array.from(contentContainer.children).forEach(div => {
                        div.classList.toggle('active', div.id === `${panel}-${type}`);
                    });
                }

                // ── Custom confirm helper (avoids native confirm() flicker) ──
                function showConfirm(message, onOk, icon) {
                    var modal = document.getElementById('confirmModal');
                    document.getElementById('confirm-message').textContent = message;
                    document.getElementById('confirm-icon').textContent = icon || '⚠️';
                    modal.style.display = 'flex';
                    var okBtn = document.getElementById('confirm-ok-btn');
                    var cancelBtn = document.getElementById('confirm-cancel-btn');
                    function cleanup() {
                        modal.style.display = 'none';
                        okBtn.onclick = null;
                        cancelBtn.onclick = null;
                    }
                    okBtn.onclick = function () { cleanup(); onOk(); };
                    cancelBtn.onclick = cleanup;
                }

                // Actions
                function closeModal(id) { document.getElementById(id).style.display = 'none'; }
                window.onclick = function (e) { if (e.target.classList.contains('modal')) e.target.style.display = 'none'; }

                async function scaleWorkload(name, type, action) {
                    showConfirm('Scale ' + type + ' "' + name + '" ' + action + '?', async function () {
                        try {
                            const ns = document.getElementById('namespace-select').value;
                            const response = await fetch('/api/scale', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ name: name, type: type, action: action, namespace: ns })
                            });
                            const data = await response.json();
                            if (!response.ok) throw new Error(data.error || response.statusText);
                            if (data.error) throw new Error(data.error);
                            fetchData();
                            showToast('Successfully scaled ' + name, true);
                        } catch (e) { showToast('Error scaling: ' + e.message, false); }
                    }, '📐');
                }

                function openLogsModal(podName) {
                    document.getElementById('logModal').style.display = 'block';
                    document.getElementById('modal-title').innerText = `Logs: ${podName}`;
                    document.getElementById('log-content').innerText = "Loading...";
                    const ns = document.getElementById('namespace-select').value;
                    fetch(`/api/pods/${podName}/logs?namespace=${ns}`)
                        .then(r => r.json())
                        .then(d => document.getElementById('log-content').innerText = d.logs || d.error)
                        .catch(e => document.getElementById('log-content').innerText = e);
                }

                function openEnvModal(name, type) {
                    document.getElementById('envModal').style.display = 'block';
                    document.getElementById('env-title').innerText = `Config: ${name}`;
                    document.getElementById('env-loading').style.display = 'block';
                    document.getElementById('env-content').style.display = 'none';

                    const ns = document.getElementById('namespace-select').value;
                    fetch(`/api/workloads/env?name=${name}&type=${type}&namespace=${ns}`)
                        .then(r => r.json())
                        .then(data => {
                            if (data.error) throw new Error(data.error);

                            document.getElementById('env-loading').style.display = 'none';
                            document.getElementById('env-content').style.display = 'block';

                            const tbody = document.querySelector('#env-table tbody');
                            tbody.innerHTML = (data.env || []).map(e => `<tr><td>${e.container}</td><td>${e.name}</td><td>${e.value}</td></tr>`).join('');
                            if (!data.env || data.env.length === 0) tbody.innerHTML = '<tr><td colspan="3">No variables</td></tr>';

                            document.getElementById('cm-list').innerHTML = (data.config_maps || []).map(c => `<button class="btn btn-default" onclick="openConfigMapModal('${c}')">${c}</button>`).join(' ') || 'None';
                            document.getElementById('secret-list').innerHTML = (data.secrets || []).map(s => `<button class="btn btn-default" onclick="openSecretModal('${s}')">🔒 ${s}</button>`).join(' ') || 'None';
                        })
                        .catch(e => {
                            document.getElementById('env-loading').style.display = 'none';
                            document.getElementById('env-content').style.display = 'block';
                            document.querySelector('#env-table tbody').innerHTML = `<tr><td colspan="3" style="color:red;">Error fetching data: ${e.message}</td></tr>`;
                        });
                }

                function openConfigMapModal(name) {
                    document.getElementById('cmContentModal').style.display = 'block';
                    document.getElementById('cm-title').innerText = `ConfigMap: ${name}`;
                    document.getElementById('cm-content').innerText = "Loading...";
                    const ns = document.getElementById('namespace-select').value;

                    fetch(`/api/configmaps/${name}?namespace=${ns}`)
                        .then(r => r.json())
                        .then(data => {
                            if (data.error) {
                                document.getElementById('cm-content').innerText = "Error: " + data.error;
                            } else {
                                // Pretty print JSON if possible
                                const content = JSON.stringify(data.data, null, 2);
                                document.getElementById('cm-content').innerText = content;
                            }
                        })
                        .catch(e => document.getElementById('cm-content').innerText = "Error: " + e);
                }

                function openSecretModal(name) {
                    const modal = document.getElementById('secretModal');
                    const title = document.getElementById('secret-title');
                    const loading = document.getElementById('secret-loading');
                    const errorDiv = document.getElementById('secret-error');
                    const dataContainer = document.getElementById('secret-data-container');
                    const tbody = document.getElementById('secret-table-body');
                    const currentNamespace = document.getElementById('namespace-select').value;

                    modal.style.display = 'block';
                    loading.style.display = 'block';
                    errorDiv.style.display = 'none';
                    dataContainer.style.display = 'none';
                    title.innerHTML = `<span>🔒</span> Secret: ${name} <small style="font-size: 12px; color: #777;">(${currentNamespace})</small>`;
                    tbody.innerHTML = '';

                    fetch(`/api/secrets/${name}?namespace=${currentNamespace}`)
                        .then(r => {
                            if (!r.ok) return r.json().then(d => { throw new Error(d.error || 'Fetch failed'); });
                            return r.json();
                        })
                        .then(data => {
                            if (data.error) throw new Error(data.error);

                            loading.style.display = 'none';
                            dataContainer.style.display = 'block';

                            // Render Data
                            if (data.data) {
                                Object.keys(data.data).forEach(key => {
                                    tbody.innerHTML += `
                                        <tr>
                                            <td style="font-weight:bold; color:#0056b3;">${key}</td>
                                            <td style="font-family:monospace; background:#f8f8f8;">${data.data[key]}</td>
                                        </tr>`;
                                });
                            }
                        })
                        .catch(err => {
                            loading.style.display = 'none';
                            errorDiv.style.display = 'block';
                            errorDiv.innerText = `⛔ ${err.message || 'Access Denied'}`;
                        });
                }

                function openTerminalPrompt(podName, containersJson) {
                    const containers = JSON.parse(decodeURIComponent(containersJson));

                    if (containers.length === 0) {
                        alert("No containers found in this pod.");
                        return;
                    }

                    if (containers.length === 1) {
                        // Direct connect
                        openTerminal(podName, containers[0].name);
                    } else {
                        // Show selection modal
                        const modal = document.getElementById('containerSelectModal');
                        const list = document.getElementById('container-list');

                        list.innerHTML = containers.map(c =>
                            `<button class="btn btn-default" style="text-align: left; padding: 10px;" onclick="selectContainer('${podName}', '${c.name}')">
                                <strong>${c.name}</strong>
                            </button>`
                        ).join('');

                        modal.style.display = 'block';
                    }
                }

                function selectContainer(podName, containerName) {
                    closeModal('containerSelectModal');
                    openTerminal(podName, containerName);
                }

                function analyzeResource(name, type, status) {
                    document.getElementById('rcaModal').style.display = 'block';
                    document.getElementById('rca-loading').style.display = 'block';
                    document.getElementById('rca-content').style.display = 'none';

                    const ns = document.getElementById('namespace-select').value;
                    fetch('/api/ai/rca', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ name: name, type: type, status: status, namespace: ns })
                    })
                        .then(r => {
                            if (!r.ok) return r.json().then(e => { throw new Error(e.error || r.statusText) });
                            return r.json();
                        })
                        .then(data => {
                            document.getElementById('rca-loading').style.display = 'none';
                            const content = document.getElementById('rca-content');

                            if (data.error) throw new Error(data.error);
                            if (!data.analysis) throw new Error("No analysis returned from AI.");

                            content.style.display = 'block';
                            // Simple markdown-ish rendering for bold/headers
                            let html = data.analysis
                                .replace(/### (.*)/g, '<h3 style="margin-top:0; color:#333;">$1</h3>')
                                .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
                                .replace(/- (.*)/g, '<li>$1</li>');
                            content.innerHTML = html;
                        })
                        .catch(e => {
                            document.getElementById('rca-loading').style.display = 'none';
                            document.getElementById('rca-content').innerText = "Error: " + e.message;
                            document.getElementById('rca-content').style.display = 'block';
                        });
                }


                function summarizeLogs() {
                    const logText = document.getElementById('log-content').innerText;
                    const summaryBox = document.getElementById('log-summary-box');
                    const summaryContent = document.getElementById('log-summary-content');

                    summaryBox.style.display = 'block';
                    summaryContent.innerText = "Analyzing log patterns...";

                    fetch('/api/ai/summarize_logs', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ logs: logText })
                    })
                        .then(r => {
                            if (!r.ok) return r.json().then(e => { throw new Error(e.error || r.statusText) });
                            return r.json();
                        })
                        .then(data => {
                            if (data.error) throw new Error(data.error);

                            let html = data.summary
                                .replace(/### (.*)/g, '<h4 style="margin: 5px 0; color:#333;">$1</h4>')
                                .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
                                .replace(/- (.*)/g, '<li style="margin-left: 20px;">$1</li>');
                            summaryContent.innerHTML = `<ul style="margin: 0; padding: 0; list-style: none;">${html}</ul>`;
                        })
                        .catch(e => {
                            summaryContent.innerText = "Error summarizing logs: " + e.message;
                        });
                }


                function openOptimizer() {
                    document.getElementById('optimizerModal').style.display = 'block';
                    document.getElementById('opt-loading').style.display = 'block';
                    document.getElementById('opt-content').style.display = 'none';

                    const currentNamespace = document.getElementById('namespace-select').value;
                    fetch(`/api/ai/optimize?namespace=${currentNamespace}`)
                        .then(r => {
                            if (!r.ok) return r.json().then(e => { throw new Error(e.error || r.statusText) });
                            return r.json();
                        })
                        .then(data => {
                            if (data.error) throw new Error(data.error);

                            document.getElementById('opt-loading').style.display = 'none';
                            document.getElementById('opt-content').style.display = 'block';
                            const tbody = document.getElementById('opt-table-body');
                            tbody.innerHTML = '';

                            data.recommendations.forEach(rec => {
                                const tr = document.createElement('tr');
                                tr.innerHTML = `
                                <td style="font-weight: bold;">${rec.type}</td>
                                <td>${rec.resource}</td>
                                <td>${rec.reason}</td>
                                <td style="color: #28a745; font-weight: 500;">${rec.action}</td>
                                <td>${rec.impact}</td>
                            `;
                                tbody.appendChild(tr);
                            });

                            if (data.recommendations.length === 0) {
                                tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;">✅ No optimization opportunities found. Resources are efficient!</td></tr>';
                            }
                        })
                        .catch(e => {
                            document.getElementById('opt-loading').style.display = 'none';
                            document.getElementById('opt-content').style.display = 'block';
                            document.getElementById('opt-table-body').innerHTML = `<tr><td colspan="5" style="color:red;">Error: ${e.message}</td></tr>`;
                        });
                }

                function openConfigMapModal(name) {
                    document.getElementById('cmContentModal').style.display = 'block';
                    document.getElementById('cm-content').innerText = 'Loading...';
                    document.getElementById('cm-title').innerText = `CM: ${name}`;
                    const ns = document.getElementById('namespace-select').value;
                    fetch(`/api/configmaps/${name}?namespace=${ns}`)
                        .then(r => r.json())
                        .then(d => document.getElementById('cm-content').innerText = d.error ? d.error : JSON.stringify(d.data, null, 2));
                }

                // Terminal Logic
                let socket;
                let term;
                let fitAddon;

                function openTerminal(podName, containerName) {
                    // ALERT FOR DEBUGGING
                    // alert("Debug: Opening terminal for " + podName); 

                    try {
                        const debugEl = document.getElementById('term-debug');
                        if (debugEl) debugEl.innerText = "Status: Initializing function...";

                        document.getElementById('terminalModal').style.display = 'block';
                        document.getElementById('terminal-title').innerText = `Terminal: ${podName}`;

                        if (typeof Terminal === 'undefined') {
                            throw new Error("xterm.js is not loaded");
                        }

                        if (term) term.dispose();

                        term = new Terminal({
                            cursorBlink: true,
                            theme: { background: '#1e1e1e' }
                        });

                        if (typeof FitAddon !== 'undefined') {
                            fitAddon = new FitAddon.FitAddon();
                            term.loadAddon(fitAddon);
                        }

                        // Delay opening to ensure modal is visible and has dimensions
                        setTimeout(() => {
                            try {
                                if (debugEl) debugEl.innerText = "Status: Opening xterm...";

                                const container = document.getElementById('terminal-container');
                                if (!container) throw new Error("Terminal container div not found");

                                term.open(container);

                                // Force initial size before fit
                                term.resize(80, 24);

                                if (fitAddon) {
                                    try {
                                        fitAddon.fit();
                                    } catch (e) { console.error("Fit error:", e); }
                                }

                                term.write('Connecting to terminal...\r\n');
                                if (debugEl) debugEl.innerText = "Status: Connecting Socket...";

                                // Explicitly define URL (auto-detection usually works)
                                socket = io();

                                socket.on('connect', () => {
                                    console.log('Socket connected');
                                    if (debugEl) {
                                        debugEl.innerText = "Status: Connected! Requesting shell...";
                                        debugEl.style.color = "lime";
                                    }

                                    socket.emit('connect_terminal', {
                                        namespace: document.getElementById('namespace-select').value,
                                        pod: podName,
                                        container: containerName
                                    });
                                });

                                socket.on('connect_error', (err) => {
                                    if (debugEl) {
                                        debugEl.innerText = "Status: Connection Error: " + err;
                                        debugEl.style.color = "red";
                                    }
                                    term.write(`\r\nConnection Error: ${err}\r\n`);
                                });

                                socket.on('terminal_output', (d) => {
                                    if (debugEl) debugEl.innerText = "Status: Received Data";
                                    console.log('Term output:', d.data);
                                    term.write(d.data);
                                });
                                socket.on('terminal_error', (d) => term.write(`\r\nError: ${d.data}\r\n`));
                                term.onData(d => socket.emit('terminal_input', { data: d }));
                            } catch (innerE) {
                                alert("Error inside timeout: " + innerE.message);
                            }
                        }, 200);

                        window.addEventListener('resize', resizeTerminal);
                    } catch (e) {
                        alert("Critical Error opening terminal: " + e.message);
                        console.error(e);
                    }
                }

                function resizeTerminal() { if (fitAddon) fitAddon.fit(); }

                function closeTerminal() {
                    document.getElementById('terminalModal').style.display = 'none';
                    if (socket) socket.disconnect();
                    if (term) term.dispose();
                    window.removeEventListener('resize', resizeTerminal);
                }

                function openEventsModal(name) {
                    document.getElementById('eventsModal').style.display = 'block';
                    document.getElementById('events-title').innerText = `Events: ${name}`;
                    document.getElementById('events-loading').style.display = 'block';
                    document.getElementById('events-table-body').innerHTML = '';

                    const ns = document.getElementById('namespace-select').value;
                    fetch(`/api/events/${name}?namespace=${ns}`)
                        .then(r => {
                            if (!r.ok) return r.json().then(e => { throw new Error(e.error || r.statusText) });
                            return r.json();
                        })
                        .then(data => {
                            if (data.error) throw new Error(data.error);

                            document.getElementById('events-loading').style.display = 'none';
                            const tbody = document.getElementById('events-table-body');
                            if (data.events && data.events.length > 0) {
                                tbody.innerHTML = data.events.map(e => `
                                    <tr>
                                        <td>${e.type}</td>
                                        <td>${e.reason}</td>
                                        <td>${e.message}</td>
                                        <td>${e.count}</td>
                                        <td>${new Date(e.last_timestamp).toLocaleString()}</td>
                                    </tr>
                                `).join('');
                            } else {
                                tbody.innerHTML = '<tr><td colspan="5">No events found.</td></tr>';
                            }
                        })
                        .catch(e => {
                            document.getElementById('events-loading').innerText = "Error: " + e.message;
                        });
                }

