# ── Vertex AI / Gemini Authentication ─────────────────────────────────────────
#
# Auto-detects the credential type from GOOGLE_APPLICATION_CREDENTIALS at
# startup. No code changes needed when switching between environments.
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │ MODE 1 — Workload Identity Federation (WIF / Keyless)                  │
# │                                                                         │
# │ Use when: on-prem GDC connected to GCP via Azure AD / AWS / OIDC       │
# │ Set:      GOOGLE_APPLICATION_CREDENTIALS=/path/to/wif-config.json      │
# │ File has: { "type": "external_account", "audience": "//iam.googleapis  │
# │             .com/projects/.../workloadIdentityPools/..." }              │
# │                                                                         │
# │ How it works at runtime (every Gemini API call):                        │
# │  1. google-auth reads the audience + credential_source from the file    │
# │  2. Fetches a short-lived Azure AD / OIDC token from the local          │
# │     metadata endpoint (e.g. Azure IMDS at 169.254.169.254)             │
# │  3. POSTs that token to GCP Security Token Service (STS):               │
# │       POST https://sts.googleapis.com/v1/token                         │
# │       body: { audience, subject_token: <azure-jwt>, grant_type }       │
# │  4. GCP STS validates the Azure token against the trusted WIF provider  │
# │     and returns a short-lived federated access token (1 hr TTL)         │
# │  5. (Optional) Exchanges it for a SA-scoped token via IAM Credentials  │
# │  6. Uses that token to call Vertex AI / Gemini                          │
# │  7. google-auth auto-refreshes tokens when < 5 min remaining           │
# │  ✅ No static secrets — Azure identity rotates tokens automatically     │
# │                                                                         │
# ├─────────────────────────────────────────────────────────────────────────┤
# │ MODE 2 — Classic Service Account JSON Key                               │
# │                                                                         │
# │ Use when: simpler setup, or WIF not yet configured                      │
# │ Set:      GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa-key.json          │
# │ File has: { "type": "service_account", "client_email": "...",           │
# │             "private_key": "-----BEGIN RSA PRIVATE KEY-----..." }       │
# │                                                                         │
# │ How it works at runtime (every Gemini API call):                        │
# │  1. google-auth reads the RSA private key from the JSON file            │
# │  2. Signs a JWT locally using the private key (no network call needed)  │
# │  3. POSTs the signed JWT to GCP token endpoint:                         │
# │       POST https://oauth2.googleapis.com/token                         │
# │  4. GCP verifies the signature against the SA public key and returns    │
# │     a short-lived OAuth2 access token (1 hr TTL)                        │
# │  5. Uses that token to call Vertex AI / Gemini                          │
# │  ⚠️  Key file is a static secret — rotate every 90 days, store in K8s  │
# │     Secret, never commit to source control                              │
# │                                                                         │
# ├─────────────────────────────────────────────────────────────────────────┤
# │ MODE 3 — Application Default Credentials (ADC)                          │
# │                                                                         │
# │ Use when: local development with `gcloud auth application-default login`│
# │ Set:      (do not set GOOGLE_APPLICATION_CREDENTIALS)                  │
# │ google.auth.default() checks in order:                                 │
# │   1. GOOGLE_APPLICATION_CREDENTIALS env var (not set → skip)           │
# │   2. ~/.config/gcloud/application_default_credentials.json             │
# │   3. GCE/Cloud Run/GKE metadata server                                 │
# └─────────────────────────────────────────────────────────────────────────┘
GCP_SCOPES = ["https://www.googleapis.com/auth/cloud-platform"]

def _load_gcp_credentials():
    """Auto-detect and load GCP credentials from GOOGLE_APPLICATION_CREDENTIALS.

    Reads the JSON file pointed to by the env var, inspects the 'type' field,
    and routes to the appropriate credential loader. Falls back to ADC if the
    env var is not set.

    Returns:
        (credentials, description_string) tuple.
    Raises:
        RuntimeError if the file cannot be read or has an unrecognised type.
    """
    sa_key_path = os.getenv("GOOGLE_APPLICATION_CREDENTIALS")

    if not sa_key_path:
        # Mode 3 — no file set, fall back to ADC (gcloud / metadata server)
        credentials, _ = google.auth.default(scopes=GCP_SCOPES)
        return credentials, "Application Default Credentials (GOOGLE_APPLICATION_CREDENTIALS not set)"

    try:
        with open(sa_key_path) as f:
            key_data = json.load(f)
    except (OSError, json.JSONDecodeError) as e:
        raise RuntimeError(f"Cannot read credential file '{sa_key_path}': {e}")

    cred_type = key_data.get("type", "unknown")

    if cred_type == "external_account":
        # Mode 1 — WIF: google-auth handles Azure→GCP STS token exchange
        # transparently on every API call. No static secrets in the file.
        credentials, _ = google.auth.load_credentials_from_file(
            sa_key_path, scopes=GCP_SCOPES
        )
        audience = key_data.get("audience", "unknown")
        return credentials, f"Workload Identity Federation | audience: {audience}"

    elif cred_type == "service_account":
        # Mode 2 — SA key: google-auth signs a JWT locally with the RSA
        # private key and exchanges it for a GCP OAuth2 access token.
        credentials = service_account.Credentials.from_service_account_file(
            sa_key_path, scopes=GCP_SCOPES
        )
        sa_email = key_data.get("client_email", "unknown")
        return credentials, f"Service Account key | {sa_email}"

    else:
        raise RuntimeError(
            f"Unknown credential type '{cred_type}' in '{sa_key_path}'. "
            "Expected 'external_account' (WIF) or 'service_account' (SA key)."
        )

try:
    PROJECT_ID = os.getenv("GOOGLE_CLOUD_PROJECT", "gdc-dashboard-demo")
    LOCATION   = os.getenv("GOOGLE_CLOUD_REGION", "us-central1")

    credentials, cred_description = _load_gcp_credentials()
    vertexai.init(project=PROJECT_ID, location=LOCATION, credentials=credentials)
    print(f"Vertex AI Initialized: {cred_description}")

    model = GenerativeModel("gemini-2.5-flash")
    chat_session = model.start_chat()
    print(f"Gemini model ready: gemini-2.5-flash ({PROJECT_ID}/{LOCATION})")
except Exception as e:
    print(f"Warning: Vertex AI init failed: {e}")
    model = None
    chat_session = None

